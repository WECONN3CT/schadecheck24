        <!-- CTA Buttons - DESKTOP -->
        <div class="flex flex-col sm:flex-row gap-3 sm:gap-4">
          <!-- Phone Button (Highlight Turquoise) -->
          <a
            href="tel:+4921917932020"
            class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-[#7DD3E8] hover:bg-[#5DC3DD] text-[#003366] font-semibold px-4 sm:px-6 py-3 sm:py-4 rounded-lg text-sm sm:text-base transition-all duration-200 transform hover:scale-105 hover:shadow-lg drop-shadow-md"
            data-analytics="phone-click"
