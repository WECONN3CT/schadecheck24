---
import { Image } from 'astro:assets';

// Import background
import backgroundHero from '~/assets/images/Hero elements floating/background hero.webp';
import heroMobile from '~/assets/images/Hero elements floating/hero mobile.png';

// Import floating elements
import element1 from '~/assets/images/Hero elements floating/013_7_11zon.webp';
import element2 from '~/assets/images/Hero elements floating/014_1_11zon.webp';
import element3 from '~/assets/images/Hero elements floating/015_2_11zon.webp';
import element4 from '~/assets/images/Hero elements floating/016_3_11zon.webp';
import element5 from '~/assets/images/Hero elements floating/018_5_11zon.webp';
import bumper from '~/assets/images/Hero elements floating/bumper.webp';

interface Props {
  id?: string;
  title?: string;
  subtitle?: string;
}

const { id = 'floating-hero', title, subtitle } = Astro.props;
---

<!-- ===== DESKTOP VERSION (hidden on mobile) ===== -->
<section
  class="floating-hero-section relative overflow-hidden hidden md:block"
  {...id ? { id } : {}}
  data-floating-hero
>
  <!-- Background Image (Stretched) -->
  <div class="absolute inset-0 z-0">
    <Image
      src={backgroundHero}
      alt="Unfallfahrzeug Hintergrund für Kfz Gutachter Remscheid und KFZ Sachverständiger Remscheid Unfallgutachten & Wertgutachten"
      class="w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
      width={1920}
      height={1080}
    />
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0.2) 50%, rgba(2,15,20,0.8) 100%);"></div>
  </div>

  <!-- Floating Elements Container - Clipped to prevent overflow -->
  <div class="floating-elements-container absolute inset-0 z-10 pointer-events-none overflow-hidden" aria-hidden="true">
    <!-- Element 1 (013_7): Fliegt stark nach oben links -->
    <div
      class="floating-element"
      data-start-x="70"
      data-start-y="55"
      data-end-x="8"
      data-end-y="5"
      data-repel-strength="100"
    >
      <Image src={element1} alt="Beschädigtes Fahrzeugteil für Kfz Gutachter Remscheid Unfallgutachten und Wertgutachten" width={160} height={160} loading="eager" class="w-20 sm:w-24 md:w-36 lg:w-40 opacity-0" />
    </div>

    <!-- Element 5 (018_5): Fliegt nach links mitte -->
    <div
      class="floating-element"
      data-start-x="70"
      data-start-y="55"
      data-end-x="15"
      data-end-y="40"
      data-repel-strength="120"
    >
      <Image src={element5} alt="Karosserieschaden mit Kfz Gutachter Remscheid und KFZ Sachverständiger Remscheid für Unfallgutachten" width={175} height={175} loading="eager" class="w-24 sm:w-28 md:w-40 lg:w-48 opacity-0" />
    </div>

    <!-- Bumper: Fliegt nach unten links -->
    <div
      class="floating-element"
      data-start-x="70"
      data-start-y="55"
      data-end-x="5"
      data-end-y="75"
      data-repel-strength="110"
    >
      <Image src={bumper} alt="Beschädigte Stoßstange - Kfz Gutachter Remscheid KFZ Sachverständiger Remscheid Unfallgutachten" width={450} height={450} loading="eager" class="w-48 sm:w-56 md:w-80 lg:w-96 opacity-0" />
    </div>
  </div>

  <!-- Content Overlay (Text) - DESKTOP VERSION -->
  <div class="relative z-20 max-w-7xl mx-auto px-4 sm:px-6 py-20 md:pt-8 md:pb-32 lg:pt-12 lg:pb-40">
    <div class="text-white">
      <!-- Content starts at ~15% from left -->
      <div class="ml-0 md:ml-[15%] max-w-3xl">
        {
          title && (
            <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold mb-4 drop-shadow-lg text-left" set:html={title} />
          )
        }
        {
          subtitle && (
            <p class="text-sm sm:text-base md:text-3xl lg:text-4xl font-semibold text-gray-100 mb-8 drop-shadow-md text-left" set:html={subtitle} />
          )
        }

        <!-- USP Checkmarks in Pastel Turquoise (Left-aligned) -->
        <div class="space-y-3 mb-8">
          <div class="flex items-start gap-2 sm:gap-3">
            <svg class="w-5 h-5 sm:w-6 sm:h-6 text-[#7DD3E8] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            <span class="text-xs sm:text-sm md:text-lg lg:text-xl drop-shadow-md">Sofortige Unterstützung direkt bei Ihnen vor Ort</span>
          </div>
          <div class="flex items-start gap-2 sm:gap-3">
            <svg class="w-5 h-5 sm:w-6 sm:h-6 text-[#7DD3E8] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            <span class="text-xs sm:text-sm md:text-lg lg:text-xl drop-shadow-md">Rundum-Service aus einer Hand</span>
