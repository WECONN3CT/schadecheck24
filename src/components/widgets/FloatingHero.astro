<style>
  .floating-hero-section {
    min-height: 500px;
    height: 70vh;
    max-height: 800px;
    position: relative;
  }

  /* Floating Elements - Explosion Effect */
  .floating-element {
    position: absolute;
    will-change: transform;
    /* Kein transition hier - Animation per JS */
  }

  .floating-element img {
    will-change: opacity;
    /* Kein transition - Animation per JS für smooth performance */
  }

  /* Subtle idle floating after explosion - DEAKTIVIERT wegen Konflikten */
  /* Die Elemente bleiben nach der Explosion an ihrer Position */
  /* Nur Cursor-Repel-Effekt ist aktiv */

  /* Reduced Motion Support (Accessibility) */
  @media (prefers-reduced-motion: reduce) {
    .floating-element {
      animation: none !important;
      transition: none !important;
    }
  }

  /* Mobile Optimization */
  @media (max-width: 768px) {
    .floating-hero-section {
      min-height: 400px;
      height: 60vh;
    }

    /* Reduce opacity on mobile for better text readability */
    .floating-element img {
      opacity: 0.7 !important;
    }
  }
</style>

<script>
  // Explosion Effect Controller - nur für Desktop Version
  class FloatingHeroController {
    private section: HTMLElement | null = null;
    private elements: HTMLElement[] = [];
    private isVisible = false;
    private hasPointer = false;
    private hasExploded = false;
    private isAnimating = false;
    private mouseX = 0;
    private mouseY = 0;
    private isUpdating = false;
    private observer: IntersectionObserver | null = null;
    private elementData: Array<{
      element: HTMLElement;
      startX: number;
      startY: number;
      endX: number;
      endY: number;
      currentX: number;
      currentY: number;
      repelStrength: number;
      velocityX: number;
      velocityY: number;
      width: number;
      height: number;
    }> = [];

    constructor() {
      this.init();
    }

    private init(): void {
      this.section = document.querySelector('[data-floating-hero]');
      if (!this.section) return;

      this.elements = Array.from(this.section.querySelectorAll('.floating-element'));

      // Parse element data
      this.elements.forEach((element) => {
        const startX = parseFloat(element.getAttribute('data-start-x') || '75');
        const startY = parseFloat(element.getAttribute('data-start-y') || '70');
        const endX = parseFloat(element.getAttribute('data-end-x') || '50');
        const endY = parseFloat(element.getAttribute('data-end-y') || '50');
        const repelStrength = parseFloat(element.getAttribute('data-repel-strength') || '100');

        // Set initial position (at car) with GPU acceleration
        element.style.position = 'absolute';
        element.style.left = `${startX}%`;
        element.style.top = `${startY}%`;
        element.style.transform = 'translate3d(-50%, -50%, 0)';
        element.style.backfaceVisibility = 'hidden';
        element.style.perspective = '1000px';

        // Set initial image opacity
        const img = element.querySelector('img');
        if (img) {
          img.style.opacity = '0';
        }

        // Cache element dimensions once (vor Animation)
        const rect = element.getBoundingClientRect();

        this.elementData.push({
          element,
          startX,
          startY,
          endX,
          endY,
          currentX: startX,
          currentY: startY,
          repelStrength,
          velocityX: 0,
          velocityY: 0,
          width: rect.width || 200,
          height: rect.height || 200,
        });
      });

      // Detect if device has pointer (desktop)
      this.hasPointer = window.matchMedia('(pointer: fine)').matches;

      // Setup Intersection Observer
      this.setupIntersectionObserver();

      // Only add mousemove on desktop
      if (this.hasPointer) {
        this.section.addEventListener('mousemove', this.handleMouseMove.bind(this));
      }
    }

    private setupIntersectionObserver(): void {
      this.observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            this.isVisible = entry.isIntersecting;

            if (this.isVisible && !this.hasExploded) {
              // Trigger explosion when visible
              this.triggerExplosion();
              this.hasExploded = true;
            }
          });
        },
        {
          threshold: 0.3, // Trigger when 30% visible
        }
      );

      if (this.section) {
        this.observer.observe(this.section);
      }
    }

    private triggerExplosion(): void {
      // Setze Animation-Flag und blockiere Cursor-Interaktion
      this.isAnimating = true;

      // Explosion animation in slow motion
      this.elementData.forEach((data, index) => {
        // Animate to end position with easing (slow start, then decelerate)
        this.animateExplosion(data, index);
      });
    }

    private animateExplosion(data: any, index: number): void {
      const duration = 3500; // 3.5 seconds - langsamer
      const startTime = performance.now() + index * 200; // Staggered start
      const img = data.element.querySelector('img');

      // Calculate total animation time including stagger
      const totalAnimationTime = duration + index * 200;
      const isLastElement = index === this.elementData.length - 1;

      // Calculate total distance in pixels (for smooth animation)
      const sectionRect = this.section!.getBoundingClientRect();

      // Berechne Browser-Grenzen basierend auf Element-Größe
      const elementWidth = data.width;
      const elementHeight = data.height;

      // Min/Max Positionen in Prozent (damit Element vollständig sichtbar bleibt)
      const minXPercent = (elementWidth / 2 / sectionRect.width) * 100;
      const maxXPercent = ((sectionRect.width - elementWidth / 2) / sectionRect.width) * 100;
      const minYPercent = (elementHeight / 2 / sectionRect.height) * 100;
      const maxYPercent = ((sectionRect.height - elementHeight / 2) / sectionRect.height) * 100;

      // Clampe Endposition innerhalb der Grenzen
      const clampedEndX = Math.max(minXPercent, Math.min(maxXPercent, data.endX));
      const clampedEndY = Math.max(minYPercent, Math.min(maxYPercent, data.endY));

      // Berechne Distanz mit geclampten Endpositionen
      const totalDistanceX = ((clampedEndX - data.startX) / 100) * sectionRect.width;
      const totalDistanceY = ((clampedEndY - data.startY) / 100) * sectionRect.height;

      const animate = (currentTime: number) => {
        const elapsed = currentTime - startTime;
        if (elapsed < 0) {
          requestAnimationFrame(animate);
          return;
        }

        const progress = Math.min(elapsed / duration, 1);

        // Smooth cubic easing with powerful start (keine harten Übergänge!)
        // Formel: easeOutCubic mit customization für starken Start
        const eased = 1 - Math.pow(1 - progress, 2.5);

        // Calculate movement offset in pixels (vom Startpunkt)
        const offsetX = totalDistanceX * eased;
        const offsetY = totalDistanceY * eased;

        // Calculate opacity (fade in during first 20%)
        const opacity = Math.min(progress / 0.2, 1) * 0.85;

        // Apply position via transform ONLY (NO left/top changes = NO reflow!)
        data.element.style.transform = `translate3d(calc(-50% + ${offsetX}px), calc(-50% + ${offsetY}px), 0)`;

        // Apply opacity
        if (img) {
          img.style.opacity = opacity.toString();
        }

        if (progress < 1) {
          requestAnimationFrame(animate);
        } else {
          // Animation fertig - setze finale Position in left/top (mit geclampten Werten!)
          data.currentX = clampedEndX;
          data.currentY = clampedEndY;
          data.element.style.left = `${clampedEndX}%`;
          data.element.style.top = `${clampedEndY}%`;
          data.element.style.transform = 'translate3d(-50%, -50%, 0)'; // Reset transform

          // Wenn dies das letzte Element ist: Cursor-Interaktion aktivieren
          if (isLastElement) {
            this.isAnimating = false;
          }

          // Entferne will-change nach Animation für bessere Performance
          setTimeout(() => {
            data.element.style.willChange = 'auto';
            if (img) {
              img.style.willChange = 'auto';
            }
          }, 100);
        }
      };

      requestAnimationFrame(animate);
    }

    private handleMouseMove(e: MouseEvent): void {
      if (!this.isVisible || !this.section || !this.hasExploded || this.isAnimating) return;

      const rect = this.section.getBoundingClientRect();
      this.mouseX = e.clientX - rect.left;
      this.mouseY = e.clientY - rect.top;

      // Starte kontinuierliches Update wenn nicht schon läuft
      if (!this.isUpdating) {
        this.isUpdating = true;
        this.continuousUpdate();
      }
    }

    private continuousUpdate(): void {
      if (!this.isVisible || !this.hasExploded || this.isAnimating) {
        this.isUpdating = false;
        return;
      }

      this.applyRepelEffect();

      // Weiter updaten für smooth Animation
      requestAnimationFrame(() => this.continuousUpdate());
    }

    private applyRepelEffect(): void {
      this.elementData.forEach((data) => {
        // Berechne Element-Position relativ zur Section
        const sectionRect = this.section!.getBoundingClientRect();

        // Aktuelle Position aus left/top % + velocity offset
        const currentLeftPercent = data.currentX;
        const currentTopPercent = data.currentY;

        const elementX = (currentLeftPercent / 100) * sectionRect.width + data.velocityX;
        const elementY = (currentTopPercent / 100) * sectionRect.height + data.velocityY;

        // Calculate distance from mouse to element
        const dx = elementX - this.mouseX;
        const dy = elementY - this.mouseY;
        const distance = Math.sqrt(dx * dx + dy * dy);

        // Calculate repel force
        const repelRadius = 250; // Größerer Radius für bessere Interaktion

        if (distance < repelRadius && distance > 0) {
          // Starke Abstoßung wenn nah
          const force = Math.pow(1 - distance / repelRadius, 2) * data.repelStrength * 1.5;
          const angle = Math.atan2(dy, dx);

          const pushX = Math.cos(angle) * force;
          const pushY = Math.sin(angle) * force;

          // Direkt zur velocity addieren für smooth Beschleunigung
          const acceleration = 0.3;
          data.velocityX += pushX * acceleration;
          data.velocityY += pushY * acceleration;
        }

        // Konstante leichte Dämpfung
        const damping = 0.96;
        data.velocityX *= damping;
        data.velocityY *= damping;

        // Stoppe komplett wenn velocity sehr klein
        if (Math.abs(data.velocityX) < 0.05) data.velocityX = 0;
        if (Math.abs(data.velocityY) < 0.05) data.velocityY = 0;

        // Use cached element dimensions (NO getBoundingClientRect!)
        const elementWidth = data.width;
        const elementHeight = data.height;

        // Calculate boundary limits (in pixels relative to section)
        const minX = elementWidth / 2; // Half width from left edge
        const maxX = sectionRect.width - elementWidth / 2; // Half width from right edge
        const minY = elementHeight / 2; // Half height from top edge
        const maxY = sectionRect.height - elementHeight / 2; // Half height from bottom edge

        // Calculate new position with velocity
        const newElementX = (currentLeftPercent / 100) * sectionRect.width + data.velocityX;
        const newElementY = (currentTopPercent / 100) * sectionRect.height + data.velocityY;

        // Clamp velocity to keep element within bounds
        if (newElementX < minX) {
          data.velocityX = minX - (currentLeftPercent / 100) * sectionRect.width;
        } else if (newElementX > maxX) {
          data.velocityX = maxX - (currentLeftPercent / 100) * sectionRect.width;
        }

        if (newElementY < minY) {
          data.velocityY = minY - (currentTopPercent / 100) * sectionRect.height;
        } else if (newElementY > maxY) {
          data.velocityY = maxY - (currentTopPercent / 100) * sectionRect.height;
        }

        // Apply transform mit aktueller velocity
        data.element.style.transform = `translate3d(calc(-50% + ${data.velocityX}px), calc(-50% + ${data.velocityY}px), 0)`;
      });
    }

    public destroy(): void {
      if (this.observer) {
        this.observer.disconnect();
      }
    }
  }

  // Initialize on DOM ready
  document.addEventListener('DOMContentLoaded', () => {
    new FloatingHeroController();
  });

  // Re-initialize after Astro view transitions
  document.addEventListener('astro:page-load', () => {
    new FloatingHeroController();
  });
</script>
