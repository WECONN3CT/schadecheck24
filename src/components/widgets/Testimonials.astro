---
import Headline from '~/components/ui/Headline.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Button from '~/components/ui/Button.astro';
import Image from '~/components/common/Image.astro';
import type { Testimonials as Props } from '~/types';
import { Image as AstroImage } from 'astro:assets';
import logoImage from '~/assets/images/logo.webp';

const {
  title = '',
  subtitle = '',
  tagline = '',
  testimonials = [],
  callToAction,

  id,
  isDark = false,
  classes = {},
  bg = await Astro.slots.render('bg'),
} = Astro.props;

const COLLAPSED_HEIGHT = 200;
const COLLAPSE_CHAR_THRESHOLD = 260;
---

<WidgetWrapper id={id} isDark={isDark} containerClass={`max-w-6xl mx-auto ${classes?.container ?? ''}`} bg={bg}>
  <Headline title={title} subtitle={subtitle} tagline={tagline} />

  <!-- Google Reviews Platzhalter -->
  <div class="mb-8 p-6 bg-white dark:bg-slate-800 rounded-lg border-2 border-dashed border-gray-300 dark:border-gray-600">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <!-- Google Reviews Links -->
      <div class="flex items-center gap-3">
        <svg class="w-12 h-12" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M43.611 20.083H42V20H24v8h11.303c-1.649 4.657-6.08 8-11.303 8-6.627 0-12-5.373-12-12s5.373-12 12-12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 12.955 4 4 12.955 4 24s8.955 20 20 20 20-8.955 20-20c0-1.341-.138-2.65-.389-3.917z" fill="#FFC107"/>
          <path d="M6.306 14.691l6.571 4.819C14.655 15.108 18.961 12 24 12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 16.318 4 9.656 8.337 6.306 14.691z" fill="#FF3D00"/>
          <path d="M24 44c5.166 0 9.86-1.977 13.409-5.192l-6.19-5.238A11.91 11.91 0 0124 36c-5.202 0-9.619-3.317-11.283-7.946l-6.522 5.025C9.505 39.556 16.227 44 24 44z" fill="#4CAF50"/>
          <path d="M43.611 20.083H42V20H24v8h11.303a12.04 12.04 0 01-4.087 5.571l.003-.002 6.19 5.238C36.971 39.205 44 34 44 24c0-1.341-.138-2.65-.389-3.917z" fill="#1976D2"/>
        </svg>
        <div>
          <p class="text-sm text-muted font-semibold">Google Bewertungen</p>
          <div class="flex items-center gap-2">
            <div class="flex items-center">
              {[...Array(5)].map((_, i) => (
                <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <span class="text-lg font-bold text-gray-900 dark:text-white">5.0</span>
            <span class="text-sm text-muted"></span>
          </div>
        </div>
      </div>

      <!-- Logo Rechts -->
      <div class="flex-shrink-0">
        <AstroImage
          src={logoImage}
          alt="Logo Kfz Gutachter Remscheid - KFZ Sachverständiger Remscheid für Unfallgutachten und Wertgutachten"
          class="h-16 w-auto"
          widths={[200, 400]}
          sizes="200px"
        />
      </div>
    </div>
  </div>

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {
      testimonials &&
        testimonials.map((testimonialItem, index) => {
          const { title, testimonial, name, job, image, rating } = testimonialItem;
          const isExpandable = (testimonial?.length ?? 0) > COLLAPSE_CHAR_THRESHOLD;
          const textId = `testimonial-text-${index}`;

          return (
            <div class="flex h-auto intersect-once motion-safe:md:intersect:animate-fade motion-safe:md:opacity-0 intersect-quarter">
              <div
                class="testimonial-card flex flex-col p-4 md:p-6 rounded-md shadow-xl dark:shadow-none dark:border dark:border-slate-600 bg-white dark:bg-slate-900"
                data-testimonial-card
                data-expandable={isExpandable ? 'true' : 'false'}
                data-expanded={isExpandable ? 'false' : 'true'}
                style={`--testimonial-collapsed-height: ${COLLAPSED_HEIGHT}px;`}
              >
                {title && <h2 class="text-lg font-medium leading-6 pb-4">{title}</h2>}

                {/* Star Rating */}
                {rating && (
                  <div class="flex items-center gap-1 mb-3">
                    {[...Array(5)].map((_, i) => (
                      <svg
                        class={`w-5 h-5 ${i < rating ? 'text-yellow-400' : 'text-gray-300 dark:text-gray-600'}`}
                        fill="currentColor"
                        viewBox="0 0 20 20"
                      >
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                      </svg>
                    ))}
                  </div>
                )}

                {testimonial && (
                  <Fragment>
                    <blockquote
                      id={textId}
                      class:list={['flex-auto', isExpandable && 'relative']}
                      data-collapsible-text={isExpandable ? 'true' : undefined}
                      data-collapsed-height={COLLAPSED_HEIGHT}
                    >
                      <p class="text-muted">" {testimonial} "</p>
                      {isExpandable && (
                        <div
                          class="testimonial-gradient absolute inset-x-0 bottom-0 h-16 bg-gradient-to-t from-white via-white/90 to-transparent dark:from-slate-900 dark:via-slate-900/80 pointer-events-none transition-opacity duration-200"
                          aria-hidden="true"
                        />
                      )}
                    </blockquote>

                    {isExpandable && (
                      <button
                        class="mt-3 inline-flex items-center gap-2 text-sm font-semibold text-primary transition-colors hover:text-primary/80 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/30"
                        type="button"
                        data-collapse-trigger
                        aria-expanded="false"
                        aria-controls={textId}
                      >
                        <span data-toggle-label>Mehr anzeigen</span>
                        <svg class="w-4 h-4 transition-transform" viewBox="0 0 20 20" fill="none">
                          <path d="M5 7.5 10 12.5 15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                      </button>
                    )}
                  </Fragment>
                )}

                <hr class="border-slate-200 dark:border-slate-600 my-4" />

                <div class="flex items-center">
                  {image && (
                    <div class="h-10 w-10 rounded-full border border-slate-200 dark:border-slate-600">
                      {typeof image === 'string' ? (
                        <Fragment set:html={image} />
                      ) : (
                        <Image
                          class="h-10 w-10 rounded-full border border-slate-200 dark:border-slate-600 min-w-full min-h-full"
                          width={40}
                          height={40}
                          widths={[400, 768]}
                          layout="fixed"
                          {...image}
                        />
                      )}
                    </div>
                  )}

                  <div class="grow ml-3 rtl:ml-0 rtl:mr-3">
                    {name && <p class="text-base font-semibold">{name}</p>}
                    {job && <p class="text-xs text-muted">{job}</p>}
                  </div>
                </div>
              </div>
            </div>
          );
        })
    }
  </div>
  {
    callToAction && (
      <div class="flex justify-center mx-auto w-fit mt-8 md:mt-12 font-medium">
        <Button {...callToAction} />
      </div>
    )
  }
</WidgetWrapper>

<script type="module" is:inline>
  const initTestimonials = () => {
    document.querySelectorAll('[data-testimonial-card]').forEach((card) => {
      if (card.dataset.expandable !== 'true' || card.dataset.testimonialInit === 'true') {
        return;
      }

      const text = card.querySelector('[data-collapsible-text]');
      const button = card.querySelector('[data-collapse-trigger]');

      if (!text || !button) {
        card.dataset.expandable = 'false';
        card.dataset.expanded = 'true';
        return;
      }

      const collapsedHeight =
        Number(text.dataset.collapsedHeight) ||
        Number(card.style.getPropertyValue('--testimonial-collapsed-height')?.replace('px', '')) ||
        200;
      const requiresToggle = text.scrollHeight > collapsedHeight + 4;

      if (!requiresToggle) {
        card.dataset.expandable = 'false';
        card.dataset.expanded = 'true';
        button.remove();
        card.querySelector('.testimonial-gradient')?.remove();
        return;
      }

      card.dataset.testimonialInit = 'true';

      const updateLabel = () => {
        const expanded = card.dataset.expanded === 'true';
        button.setAttribute('aria-expanded', expanded.toString());
        const label = button.querySelector('[data-toggle-label]');

        if (label) {
          label.textContent = expanded ? 'Weniger anzeigen' : 'Mehr anzeigen';
        }
      };

      updateLabel();

      button.addEventListener('click', () => {
        const expanded = card.dataset.expanded === 'true';
        card.dataset.expanded = (!expanded).toString();
        updateLabel();
      });
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTestimonials);
  } else {
    initTestimonials();
  }

  document.addEventListener('astro:page-load', initTestimonials);
</script>

<style>
  :global(.testimonial-card[data-expandable='true'] [data-collapsible-text]) {
    transition: max-height 0.3s ease;
  }

  :global(.testimonial-card[data-expandable='true'][data-expanded='false'] [data-collapsible-text]) {
    max-height: var(--testimonial-collapsed-height, 200px);
    overflow: hidden;
  }

  :global(.testimonial-card[data-expanded='true'] [data-collapse-trigger] svg) {
    transform: rotate(180deg);
  }

  :global(.testimonial-card[data-expanded='true'] .testimonial-gradient) {
    opacity: 0;
  }
</style>
