<style>
  /* ===== Sticky Call Button ===== */
  #sticky-call-button {
    position: fixed;
    bottom: 300px; /* Über dem ProvenExpert Badge (ca. 200px hoch) */
    right: 20px;
    z-index: 10000;
    width: 56px;
    height: 56px;
    background: linear-gradient(135deg, #7DD3E8 0%, #5DC3DD 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #003366;
    box-shadow: 0 4px 15px rgba(125, 211, 232, 0.5);
    transition: all 0.3s ease;
    text-decoration: none;
  }

  #sticky-call-button:hover {
    transform: scale(1.1);
    box-shadow: 0 6px 20px rgba(125, 211, 232, 0.7);
    background: linear-gradient(135deg, #9BE3F2 0%, #7DD3E8 100%);
  }

  #sticky-call-button:active {
    transform: scale(0.95);
  }

  #sticky-call-button svg {
    width: 28px;
    height: 28px;
  }

  /* Pulse Animation */
  @keyframes pulse-ring {
    0% { box-shadow: 0 0 0 0 rgba(125, 211, 232, 0.6); }
    70% { box-shadow: 0 0 0 12px rgba(125, 211, 232, 0); }
    100% { box-shadow: 0 0 0 0 rgba(125, 211, 232, 0); }
  }

  #sticky-call-button::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    animation: pulse-ring 2s ease-out infinite;
  }

  /* Mobile Call Button */
  @media (max-width: 768px) {
    #sticky-call-button {
      width: 72px;
      height: 72px;
      bottom: 30px;
      right: 22px;
    }
    #sticky-call-button svg {
      width: 24px;
      height: 24px;
    }
  }

  /* ===== Fallback ProvenExpert Badge ===== */
  #fallback-pe-badge {
    position: fixed;
    bottom: 20px;
    right: 20px;
    z-index: 9998;
    text-decoration: none;
    transition: all 0.3s ease;
    display: none; /* Standardmäßig versteckt, wird per JS aktiviert */
  }

  /* Mobile: links */
  @media (max-width: 768px) {
    #fallback-pe-badge {
      right: auto;
      left: 16px;
      bottom: 16px;
    }
  }

  .pe-badge-inner {
