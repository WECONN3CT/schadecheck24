</style>

<!-- ProvenExpert Widget Script mit Fallback -->
<script is:inline>
(function() {
  var SCRIPT_SRC = "https://s.provenexpert.net/seals/proseal-v2.js";
  var TIMEOUT_MS = 3000; // 3 Sekunden Timeout
  var fallbackBadge = document.getElementById('fallback-pe-badge');
  var widgetLoaded = false;
  var isMobile = window.innerWidth <= 768;

  var CONFIG = {
    widgetId: "ad1359a9-6219-4563-aa4f-c5a68db927b3",
    language: "de-DE",
    usePageLanguage: false,
    bannerColor: "#097E92",
    textColor: "#FFFFFF",
    showReviews: true,
    hideDate: true,
    hideName: false,
    hideOnMobile: false,
    bottom: "20px",
    stickyToSide: isMobile ? "left" : "right",
    googleStars: true,
    zIndex: "9999",
    displayReviewerLastName: false
  };

  function showFallback() {
    if (!widgetLoaded && fallbackBadge) {
      fallbackBadge.style.display = 'block';
    }
  }

  function hideFallback() {
    if (fallbackBadge) {
      fallbackBadge.style.display = 'none';
    }
  }

  function checkWidgetLoaded() {
    // Prüfe ob das offizielle Widget im DOM ist
    var peWidget = document.querySelector('[id^="pe-pro-seal"], [class*="pe-pro-seal"]');
    if (peWidget) {
      widgetLoaded = true;
      hideFallback();
      return true;
    }
    return false;
  }

  function loadOfficialWidget() {
    // Cleanup alte Elemente
    document.querySelectorAll('[id^="pe-"], [class^="pe-"]:not(#fallback-pe-badge):not(.pe-badge-inner):not(.pe-stars):not(.pe-rating):not(.pe-text):not(.pe-source):not(.pe-logo)').forEach(function(el) {
      if (el.id !== 'fallback-pe-badge' && !el.closest('#fallback-pe-badge')) {
        el.remove();
      }
    });

    var oldScript = document.querySelector('script[src*="provenexpert.net"]');
    if (oldScript) oldScript.remove();
    if (window.provenExpert) delete window.provenExpert;

    // Aktualisiere Mobile-Check
    isMobile = window.innerWidth <= 768;
    CONFIG.stickyToSide = isMobile ? "left" : "right";

    // Timeout starten - wenn Widget nicht lädt, zeige Fallback
    var timeoutId = setTimeout(function() {
      if (!checkWidgetLoaded()) {
        showFallback();
      }
    }, TIMEOUT_MS);

    // Script laden
    var script = document.createElement("script");
    script.src = SCRIPT_SRC;
    script.onload = function() {
      if (window.provenExpert && window.provenExpert.proSeal) {
        window.provenExpert.proSeal(CONFIG);

        // Nach kurzer Zeit prüfen ob Widget wirklich da ist
        setTimeout(function() {
          if (checkWidgetLoaded()) {
            clearTimeout(timeoutId);
            hideFallback();
          }
        }, 500);
      }
    };
    script.onerror = function() {
      clearTimeout(timeoutId);
      showFallback();
    };
    document.body.appendChild(script);
  }

  // Initial laden
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", loadOfficialWidget);
  } else {
    loadOfficialWidget();
  }

  // Bei Astro Navigation
  document.addEventListener("astro:after-swap", function() {
    widgetLoaded = false;
    loadOfficialWidget();
  });
})();
</script>

