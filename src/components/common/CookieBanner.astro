---
// DSGVO-konformer Datenschutz-Hinweis
// Banner ist standardmäßig SICHTBAR - JS versteckt ihn nur wenn bereits zugestimmt
---

<!-- Datenschutz-Hinweis -->
<div
  id="sc-privacy-notice"
  class="fixed bottom-0 left-0 right-0 z-50 p-4 bg-white dark:bg-slate-900 border-t-4 border-brand shadow-2xl"
  role="dialog"
  aria-labelledby="sc-privacy-title"
>
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4">
      <div class="flex-1">
        <h3 id="sc-privacy-title" class="text-lg font-bold text-brand dark:text-white mb-2">
          Datenschutz-Hinweis
        </h3>
        <p class="text-sm text-gray-700 dark:text-gray-300">
          Wir verwenden technisch notwendige Speicherungen und optionale Analyse-Dienste.
          <a href="/datenschutz/" class="text-brand underline hover:text-highlight ml-1">Mehr erfahren</a>
        </p>
      </div>
      <div class="flex flex-col sm:flex-row gap-3 w-full md:w-auto">
        <button
          id="sc-priv-deny"
          class="bg-gray-200 dark:bg-slate-700 text-gray-800 dark:text-gray-200 text-sm py-2 px-6 rounded-lg font-semibold whitespace-nowrap hover:bg-gray-300 dark:hover:bg-slate-600 transition-colors"
        >
          Nur Notwendige
        </button>
        <button
          id="sc-priv-accept"
          class="btn-primary-brand text-sm py-2 px-6 rounded-lg font-semibold whitespace-nowrap"
        >
          Alle akzeptieren
        </button>
      </div>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  // WICHTIG: Gleicher Cookie-Name wie vorher für Kompatibilität
  var COOKIE_NAME = 'schadencheck_cookie_consent';

  function checkAndHideBanner() {
    var notice = document.getElementById('sc-privacy-notice');

    // Prüfe ob bereits entschieden
    if (document.cookie.indexOf(COOKIE_NAME + '=') !== -1) {
      if (notice) notice.style.display = 'none';

      // Falls bereits zugestimmt, Events feuern
      try {
        var stored = document.cookie.split(';').find(function(c) {
          return c.trim().startsWith(COOKIE_NAME + '=');
        });
        if (stored) {
          var value = JSON.parse(decodeURIComponent(stored.split('=')[1]));
          if (value.analytics) {
            window.dispatchEvent(new CustomEvent('cookies-analytics-accepted'));
          }
          if (value.media) {
            window.dispatchEvent(new CustomEvent('cookies-media-accepted'));
            window.dispatchEvent(new CustomEvent('cookies-accepted', { detail: { maps: true } }));
          }
        }
      } catch(e) {}
      return true;
    }
    return false;
  }

  function initBanner() {
    var notice = document.getElementById('sc-privacy-notice');

    // Wenn bereits entschieden, Banner verstecken und abbrechen
    if (checkAndHideBanner()) return;

    function setChoice(acceptAll) {
      var choice = {
        essential: true,
        analytics: acceptAll,
        media: acceptAll,
        timestamp: new Date().toISOString()
      };

      var d = new Date();
      d.setTime(d.getTime() + 365*24*60*60*1000);
      document.cookie = COOKIE_NAME + '=' + encodeURIComponent(JSON.stringify(choice)) + ';expires=' + d.toUTCString() + ';path=/;SameSite=Lax';

      if (notice) notice.style.display = 'none';

      // Events feuern für Analytics & Maps
      if (acceptAll) {
        window.dispatchEvent(new CustomEvent('cookies-analytics-accepted'));
        window.dispatchEvent(new CustomEvent('cookies-media-accepted'));
        window.dispatchEvent(new CustomEvent('cookies-accepted', { detail: { maps: true } }));
      }
    }

    // Alle akzeptieren
    var acceptBtn = document.getElementById('sc-priv-accept');
    if (acceptBtn) {
      acceptBtn.onclick = function() { setChoice(true); };
    }

    // Nur Notwendige
    var denyBtn = document.getElementById('sc-priv-deny');
    if (denyBtn) {
      denyBtn.onclick = function() { setChoice(false); };
    }
  }

  // Initial ausführen
  initBanner();

  // Bei Astro View Transitions: Nach DOM-Swap erneut prüfen
  document.addEventListener('astro:after-swap', function() {
    checkAndHideBanner();
  });
})();
</script>
