---
import '@fontsource-variable/inter';
---

<style is:inline>
  /* Import Merriweather for serif headings */
  @import url('https://fonts.googleapis.com/css2?family=Merriweather:wght@700;900&display=swap');

  :root {
    /* Fonts: Inter (Sans 400/600/800), Merriweather (Serif 700/900) */
    --aw-font-sans: 'Inter Variable', 'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif;
    --aw-font-serif: 'Merriweather', Georgia, serif;
    --aw-font-heading: 'Inter Variable', 'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif;

    /* Brandfarben: brand #003366, accent #7DD3E8 (Pastell Türkis), neutral #F3F4F6, dark #111827 */
    --aw-color-primary: rgb(0 51 102); /* #003366 - brand */
    --aw-color-secondary: rgb(0 40 82); /* darker brand for secondary */
    --aw-color-accent: rgb(125 211 232); /* #7DD3E8 - pastel turquoise (replaces yellow) */
    --aw-color-highlight: rgb(125 211 232); /* #7DD3E8 - pastel turquoise for CTAs & highlights */

    --aw-color-text-heading: rgb(17 24 39); /* #111827 - dark */
    --aw-color-text-default: rgb(17 24 39); /* #111827 - dark */
    --aw-color-text-muted: rgb(107 114 128); /* neutral gray */
    --aw-color-bg-page: rgb(255 255 255);

    --aw-color-bg-page-dark: rgb(17 24 39); /* #111827 */

    /* Custom brand utilities */
    --color-brand: rgb(0 51 102);
    --color-accent: rgb(125 211 232); /* Pastel Turquoise - replaces yellow */
    --color-highlight: rgb(125 211 232); /* Pastel Turquoise - für CTAs, Checkmarks, auffällige Elemente */
    --color-neutral: rgb(243 244 246);
    --color-dark: rgb(17 24 39);

    ::selection {
      background-color: rgb(125 211 232 / 30%);
      color: rgb(0 51 102);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable', 'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif;
    --aw-font-serif: 'Merriweather', Georgia, serif;
    --aw-font-heading: 'Inter Variable', 'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif;

    --aw-color-primary: rgb(0 51 102);
    --aw-color-secondary: rgb(0 40 82);
    --aw-color-accent: rgb(125 211 232);

    --aw-color-text-heading: rgb(243 244 246);
    --aw-color-text-default: rgb(229 231 235);
    --aw-color-text-muted: rgb(156 163 175);
    --aw-color-bg-page: rgb(17 24 39);

    ::selection {
      background-color: rgb(125 211 232 / 30%);
      color: rgb(243 244 246);
    }
  }

  /* Utility classes for brand */
  .text-brand {
    color: rgb(0 51 102);
  }

  .bg-brand {
    background-color: rgb(0 51 102);
  }

  .text-accent {
    color: rgb(125 211 232);
  }

  .bg-accent {
    background-color: rgb(125 211 232);
  }

  .text-highlight {
    color: rgb(125 211 232);
  }

  .bg-highlight {
    background-color: rgb(125 211 232);
  }

  .bg-neutral {
    background-color: rgb(243 244 246);
  }

  /* Serif heading class */
  .h1-serif,
  .h2-serif,
  .h3-serif {
    font-family: 'Merriweather', Georgia, serif;
    font-weight: 900;
  }

  /* Button variants */
  .btn-primary-brand {
    background-color: rgb(0 51 102);
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: 0.375rem;
    font-weight: 600;
    transition: all 0.2s;
  }

  .btn-primary-brand:hover {
    background-color: rgb(0 40 82);
    transform: translateY(-1px);
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
  }

  .btn-secondary-brand {
    background-color: rgb(125 211 232);
    color: rgb(0 51 102);
    padding: 0.75rem 1.5rem;
    border-radius: 0.375rem;
    font-weight: 600;
    transition: all 0.2s;
  }

  .btn-secondary-brand:hover {
    background-color: rgb(105 191 212);
    transform: translateY(-1px);
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
  }

  .btn-highlight {
    background-color: rgb(125 211 232);
    color: rgb(0 51 102);
    padding: 0.75rem 1.5rem;
    border-radius: 0.375rem;
    font-weight: 600;
    transition: all 0.2s;
  }

  .btn-highlight:hover {
    background-color: rgb(105 191 212);
    transform: translateY(-1px);
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
  }

  /* WhatsApp button (same structure as btn-primary-brand, but green) */
  .btn-whatsapp {
    background-color: #25D366 !important;
    color: white !important;
    padding: 0.75rem 1.5rem !important;
    font-weight: 600 !important;
    transition: all 0.2s !important;
  }

  .btn-whatsapp:hover {
    background-color: #20BA5A !important;
    transform: translateY(-1px);
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
  }

  /* Focus states for accessibility */
  .btn-primary-brand:focus,
  .btn-secondary-brand:focus,
  .btn-highlight:focus,
  .btn-whatsapp:focus {
    outline: 2px solid rgb(125 211 232);
    outline-offset: 2px;
  }

  /* Prevent text cursor - use default cursor globally */
  * {
    cursor: default;
  }

  /* Allow pointer cursor on interactive elements */
  a, button, input[type="submit"], input[type="button"], input[type="checkbox"], input[type="radio"], select, .btn-primary-brand, .btn-secondary-brand, .btn-highlight, .btn-whatsapp, details summary {
    cursor: pointer !important;
  }

  /* Allow text cursor on input fields */
  input[type="text"], input[type="email"], input[type="tel"], input[type="password"], input[type="search"], input[type="url"], textarea {
    cursor: text !important;
  }
</style>
