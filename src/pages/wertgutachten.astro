---
import Layout from '~/layouts/PageLayout.astro';
import Features3 from '~/components/widgets/Features3.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import { testimonials } from '~/data/testimonials';

const metadata = {
  title: 'Wertgutachten Kfz-Gutachter Remscheid',
  description: 'Professionelles Wertgutachten für Ihr Fahrzeug: Verkaufswert, Wiederbeschaffungswert, Restwert. Unabhängig und anerkannt in Remscheid und ganz NRW.',
  canonical: 'https://schaden-check24.de/wertgutachten/',
};
---

<Layout metadata={metadata}>
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-b from-white to-gray-50 dark:from-slate-900 dark:to-slate-800 py-8 sm:py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-4xl mx-auto">
        <p class="text-sm sm:text-base text-brand dark:text-blue-200 font-bold tracking-wide uppercase mb-2">
          Fahrzeugbewertung
        </p>
        <h1 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold mb-4 text-brand dark:text-white leading-tight px-2">
          Kfz-Wertgutachten
        </h1>
        <p class="text-base sm:text-lg md:text-xl text-gray-600 dark:text-gray-300 mb-6 sm:mb-8 px-2">
          Ein unabhängiges Wertgutachten verschafft Ihnen Klarheit über den tatsächlichen Marktwert Ihres Fahrzeugs – ob für Verkauf, Versicherung, Erbschaft oder Scheidung.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="tel:+4921917932020"
            class="btn-primary-brand inline-flex items-center justify-center py-3 px-6 text-lg rounded-xl font-bold"
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            Jetzt anrufen
          </a>
          <a
            href="https://wa.me/4921917932020?text=Hallo%2C%20ich%20benötige%20ein%20Wertgutachten."
            target="_blank"
            rel="noopener noreferrer"
            class="btn-whatsapp inline-flex items-center justify-center py-3 px-6 text-lg rounded-xl font-bold"
          >
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path>
            </svg>
            WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Vorteile -->
  <Features3
    title="Warum ein Wertgutachten?"
    subtitle="Transparenz und Sicherheit bei jeder Fahrzeugbewertung"
    columns={2}
    items={[
      {
        title: 'Objektive Bewertung',
        description: 'Unabhängige Ermittlung des Fahrzeugwerts nach anerkannten Standards.',
        icon: 'tabler:certificate',
      },
      {
        title: 'Rechtssicher',
        description: 'Anerkannt bei Versicherungen, Behörden und Gerichten.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Verkaufsargument',
        description: 'Stärken Sie Ihre Verhandlungsposition beim Fahrzeugverkauf.',
        icon: 'tabler:chart-line',
      },
      {
        title: 'Schnelle Erstellung',
        description: 'Wir kommen zu Ihnen – Termin innerhalb von 24-48 Stunden.',
        icon: 'tabler:clock',
      },
    ]}
  />

  <!-- Testimonials -->
  <Testimonials
    title="Das sagen unsere Kunden"
    testimonials={testimonials}
  />

  <!-- Einsatzbereiche -->
  <section class="bg-neutral py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12 animate-on-scroll slide-up">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-brand dark:text-white mb-4 px-2 leading-tight">
          Wann benötigen Sie ein Wertgutachten?
        </h2>
        <p class="text-base sm:text-lg md:text-xl text-gray-600 dark:text-gray-400 max-w-3xl mx-auto">
          Vielfältige Anwendungsfälle für professionelle Fahrzeugbewertung
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white dark:bg-slate-800 rounded-2xl p-8 shadow-lg animate-on-scroll slide-up delay-100">
          <div class="w-16 h-16 bg-gradient-to-br from-[#7DD3E8] to-[#003366] rounded-xl flex items-center justify-center mb-6">
            <span class="text-4xl">💰</span>
          </div>
          <h3 class="text-xl font-bold mb-4 text-brand dark:text-white">Verkauf & Kauf</h3>
          <p class="text-gray-600 dark:text-gray-400">
            Ermittlung des realistischen Marktwerts für faire Preisverhandlungen beim Fahrzeugverkauf oder -kauf.
          </p>
        </div>

        <div class="bg-white dark:bg-slate-800 rounded-2xl p-8 shadow-lg animate-on-scroll slide-up delay-200">
          <div class="w-16 h-16 bg-gradient-to-br from-[#003366] to-[#7DD3E8] rounded-xl flex items-center justify-center mb-6">
            <span class="text-4xl">🏛️</span>
          </div>
          <h3 class="text-xl font-bold mb-4 text-brand dark:text-white">Erbschaft & Scheidung</h3>
          <p class="text-gray-600 dark:text-gray-400">
            Rechtssichere Wertermittlung für Erbauseinandersetzungen oder Vermögensaufteilung bei Scheidung.
          </p>
        </div>

        <div class="bg-white dark:bg-slate-800 rounded-2xl p-8 shadow-lg animate-on-scroll slide-up delay-300">
          <div class="w-16 h-16 bg-gradient-to-br from-[#7DD3E8] to-[#003366] rounded-xl flex items-center justify-center mb-6">
            <span class="text-4xl">🛡️</span>
          </div>
          <h3 class="text-xl font-bold mb-4 text-brand dark:text-white">Versicherung</h3>
          <p class="text-gray-600 dark:text-gray-400">
            Feststellung des Wiederbeschaffungswerts oder Restwerts nach einem Unfallschaden.
          </p>
        </div>

        <div class="bg-white dark:bg-slate-800 rounded-2xl p-8 shadow-lg animate-on-scroll slide-up delay-100">
          <div class="w-16 h-16 bg-gradient-to-br from-[#003366] to-[#7DD3E8] rounded-xl flex items-center justify-center mb-6">
            <span class="text-4xl">🚗</span>
          </div>
          <h3 class="text-xl font-bold mb-4 text-brand dark:text-white">Oldtimer & Klassiker</h3>
          <p class="text-gray-600 dark:text-gray-400">
            Spezielle Bewertung von Liebhaberfahrzeugen, Klassikern und Oldtimern.
          </p>
        </div>

        <div class="bg-white dark:bg-slate-800 rounded-2xl p-8 shadow-lg animate-on-scroll slide-up delay-200">
          <div class="w-16 h-16 bg-gradient-to-br from-[#7DD3E8] to-[#003366] rounded-xl flex items-center justify-center mb-6">
            <span class="text-4xl">🏦</span>
          </div>
          <h3 class="text-xl font-bold mb-4 text-brand dark:text-white">Finanzierung</h3>
          <p class="text-gray-600 dark:text-gray-400">
            Wertnachweis für Kredit- oder Leasingverträge bei Banken und Finanzdienstleistern.
          </p>
        </div>

        <div class="bg-white dark:bg-slate-800 rounded-2xl p-8 shadow-lg animate-on-scroll slide-up delay-300">
          <div class="w-16 h-16 bg-gradient-to-br from-[#003366] to-[#7DD3E8] rounded-xl flex items-center justify-center mb-6">
            <span class="text-4xl">📋</span>
          </div>
          <h3 class="text-xl font-bold mb-4 text-brand dark:text-white">Leasingrückgabe</h3>
          <p class="text-gray-600 dark:text-gray-400">
            Dokumentation des Fahrzeugzustands und Werts bei Leasingrückgabe zur Vermeidung von Nachforderungen.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Was beinhaltet das Gutachten? -->
  <section class="py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12 animate-on-scroll slide-up">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-brand dark:text-white mb-4 px-2 leading-tight">
          Was beinhaltet das Wertgutachten?
        </h2>
      </div>

      <div class="bg-white dark:bg-slate-800 rounded-2xl p-8 md:p-12 shadow-xl animate-on-scroll slide-up">
        <ul class="space-y-4 text-gray-600 dark:text-gray-400">
          <li class="flex items-start">
            <svg class="w-6 h-6 text-[#7DD3E8] mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            <span><strong class="text-brand dark:text-white">Fahrzeugdaten:</strong> Marke, Modell, Erstzulassung, Laufleistung, Ausstattung</span>
          </li>
          <li class="flex items-start">
            <svg class="w-6 h-6 text-[#7DD3E8] mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            <span><strong class="text-brand dark:text-white">Zustandsbewertung:</strong> Lack, Technik, Innenraum, Verschleißzustand</span>
          </li>
          <li class="flex items-start">
            <svg class="w-6 h-6 text-[#7DD3E8] mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            <span><strong class="text-brand dark:text-white">Marktanalyse:</strong> Vergleich mit aktuellen Verkaufsangeboten</span>
          </li>
          <li class="flex items-start">
            <svg class="w-6 h-6 text-[#7DD3E8] mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            <span><strong class="text-brand dark:text-white">Wertermittlung:</strong> Aktueller Marktwert, Wiederbeschaffungswert</span>
          </li>
          <li class="flex items-start">
            <svg class="w-6 h-6 text-[#7DD3E8] mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            <span><strong class="text-brand dark:text-white">Fotodokumentation:</strong> Umfassende Bildaufnahmen des Fahrzeugs</span>
          </li>
          <li class="flex items-start">
            <svg class="w-6 h-6 text-[#7DD3E8] mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            <span><strong class="text-brand dark:text-white">Schriftliches Gutachten:</strong> Detaillierte Ausfertigung mit Stempel und Unterschrift</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Regional-Bezug -->
  <section class="py-16 md:py-20 bg-white dark:bg-slate-900">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-brand dark:text-white mb-4">
          Ihr Kfz-Wertgutachter in Remscheid und Umgebung
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-400">
          Professionelle Fahrzeugbewertung im Bergischen Land
        </p>
      </div>

      <div class="prose prose-lg dark:prose-invert mx-auto">
        <p>
          Als zertifizierter Kfz-Sachverständiger in <strong>Remscheid</strong> bieten wir Ihnen professionelle Wertgutachten für alle Fahrzeugtypen und Anlässe. Ob Sie Ihr Fahrzeug verkaufen möchten, eine rechtssichere Bewertung für eine Erbschaft oder Scheidung benötigen, oder den Wert Ihres Oldtimers ermitteln lassen wollen – wir stehen Ihnen mit unserer langjährigen Erfahrung zur Seite.
        </p>

        <p>
          Im <strong>Bergischen Land</strong> – von <strong>Wuppertal</strong> über <strong>Solingen</strong> bis nach <strong>Leverkusen</strong> – sind wir Ihr verlässlicher Partner für unabhängige Fahrzeugbewertungen. Unsere Wertgutachten sind bei Versicherungen, Banken, Gerichten und Behörden anerkannt und basieren auf aktuellen Marktdaten sowie anerkannten Bewertungsmethoden.
        </p>

        <p>
          Wir kommen direkt zu Ihnen – ob nach Hause, zur Arbeit oder an einen anderen Wunschort in <strong>Remscheid</strong> und ganz <strong>NRW</strong>. Die Begutachtung erfolgt vor Ort, und Sie erhalten Ihr detailliertes Wertgutachten in der Regel innerhalb von 24-48 Stunden. Kontaktieren Sie uns noch heute für eine kostenlose Erstberatung!
        </p>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="py-16 md:py-20 bg-gradient-to-b from-gray-50 to-white dark:from-slate-800 dark:to-slate-900">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-brand dark:text-white mb-4">
          Häufig gestellte Fragen
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-400">
          Alles Wichtige zum Wertgutachten
        </p>
      </div>

      <div class="space-y-4">
        <details class="group bg-white dark:bg-slate-800 rounded-lg border border-gray-200 dark:border-slate-700 overflow-hidden">
          <summary class="flex justify-between items-center cursor-pointer px-6 py-4 font-semibold text-brand dark:text-white hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors">
            <span>Wann benötige ich ein Wertgutachten?</span>
            <svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="px-6 pb-6 text-gray-600 dark:text-gray-400">
            <p>
              Ein Wertgutachten ist immer dann sinnvoll, wenn Sie den tatsächlichen Marktwert Ihres Fahrzeugs objektiv nachweisen müssen. Typische Anlässe sind: <strong>Fahrzeugverkauf</strong> (bessere Verhandlungsposition), <strong>Erbschaft oder Scheidung</strong> (rechtssichere Wertermittlung), <strong>Versicherungsfälle</strong> (Wiederbeschaffungswert oder Restwert), <strong>Oldtimer-Bewertung</strong>, <strong>Finanzierung oder Leasing</strong> sowie <strong>steuerliche Zwecke</strong>. Auch bei Streitigkeiten über den Fahrzeugwert ist ein unabhängiges Gutachten hilfreich.
            </p>
          </div>
        </details>

        <details class="group bg-white dark:bg-slate-800 rounded-lg border border-gray-200 dark:border-slate-700 overflow-hidden">
          <summary class="flex justify-between items-center cursor-pointer px-6 py-4 font-semibold text-brand dark:text-white hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors">
            <span>Wie lange ist ein Wertgutachten gültig?</span>
            <svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="px-6 pb-6 text-gray-600 dark:text-gray-400">
            <p>
              Die Gültigkeit eines Wertgutachtens hängt vom Verwendungszweck ab. Für <strong>Verkaufszwecke</strong> ist es in der Regel <strong>3-6 Monate</strong> aktuell, da sich Marktwerte ändern können. Bei <strong>Oldtimern</strong> kann die Gültigkeit länger sein, wenn sich der Zustand nicht verändert. Für <strong>rechtliche Zwecke</strong> (Erbschaft, Scheidung) wird oft ein Stichtag festgelegt. Bei <strong>Versicherungen</strong> wird meist ein aktuelles Gutachten verlangt (nicht älter als 3 Monate). Generell gilt: Je aktueller das Gutachten, desto aussagekräftiger ist es. Bei wichtigen Anlässen sollten Sie ein frisches Gutachten erstellen lassen.
            </p>
          </div>
        </details>

        <details class="group bg-white dark:bg-slate-800 rounded-lg border border-gray-200 dark:border-slate-700 overflow-hidden">
          <summary class="flex justify-between items-center cursor-pointer px-6 py-4 font-semibold text-brand dark:text-white hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors">
            <span>Was kostet ein Wertgutachten?</span>
            <svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="px-6 pb-6 text-gray-600 dark:text-gray-400">
            <p>
              Die Kosten für ein Wertgutachten richten sich nach Fahrzeugtyp, Aufwand und Umfang der Begutachtung. Ein <strong>Standard-Wertgutachten</strong> für PKW kostet in der Regel zwischen <strong>150 und 300 Euro</strong>. Bei <strong>Oldtimern oder Liebhaberfahrzeugen</strong> kann der Preis aufgrund des höheren Aufwands bei 300-500 Euro liegen. <strong>Nutzfahrzeuge</strong> werden je nach Größe und Komplexität berechnet. Ein <strong>Kurzgutachten</strong> ist günstiger (ab 80 Euro), bietet aber weniger Details. Wir erstellen Ihnen gerne ein individuelles Angebot. Die Kosten sind in der Regel steuerlich absetzbar, wenn das Gutachten betrieblich genutzt wird.
            </p>
          </div>
        </details>

        <details class="group bg-white dark:bg-slate-800 rounded-lg border border-gray-200 dark:border-slate-700 overflow-hidden">
          <summary class="flex justify-between items-center cursor-pointer px-6 py-4 font-semibold text-brand dark:text-white hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors">
            <span>Was ist der Unterschied zwischen Marktwert und Wiederbeschaffungswert?</span>
            <svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="px-6 pb-6 text-gray-600 dark:text-gray-400">
            <p>
              Der <strong>Marktwert</strong> (auch Verkehrswert) ist der Preis, den Sie beim freien Verkauf Ihres Fahrzeugs erzielen können – also der realistische Verkaufspreis auf dem aktuellen Markt. Der <strong>Wiederbeschaffungswert</strong> hingegen ist der Betrag, den Sie aufwenden müssten, um ein gleichwertiges Fahrzeug in vergleichbarem Zustand zu kaufen. Dieser liegt meist <strong>10-20% höher</strong> als der Marktwert, da Händleraufschläge und Gewährleistungen berücksichtigt werden. Bei <strong>Versicherungsfällen</strong> ist der Wiederbeschaffungswert relevant – er zeigt, was die Wiederbeschaffung kostet. Beim <strong>Verkauf</strong> orientieren Sie sich am Marktwert.
            </p>
          </div>
        </details>

        <details class="group bg-white dark:bg-slate-800 rounded-lg border border-gray-200 dark:border-slate-700 overflow-hidden">
          <summary class="flex justify-between items-center cursor-pointer px-6 py-4 font-semibold text-brand dark:text-white hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors">
            <span>Wie lange dauert die Erstellung eines Wertgutachtens?</span>
            <svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="px-6 pb-6 text-gray-600 dark:text-gray-400">
            <p>
              Die <strong>Begutachtung vor Ort</strong> dauert je nach Fahrzeugtyp <strong>30-60 Minuten</strong>. Dabei dokumentieren wir den Zustand, erstellen Fotos und erfassen alle relevanten Daten. Das <strong>fertige schriftliche Gutachten</strong> erhalten Sie in der Regel innerhalb von <strong>24-48 Stunden</strong> nach der Begutachtung – digital per E-Mail und auf Wunsch auch per Post. Bei dringendem Bedarf (z.B. anstehender Verkauf oder Gerichtstermin) können wir die Erstellung auch beschleunigen. Einen Termin für die Begutachtung erhalten Sie meist schon innerhalb von 24 Stunden nach Ihrer Kontaktaufnahme.
            </p>
          </div>
        </details>

        <details class="group bg-white dark:bg-slate-800 rounded-lg border border-gray-200 dark:border-slate-700 overflow-hidden">
          <summary class="flex justify-between items-center cursor-pointer px-6 py-4 font-semibold text-brand dark:text-white hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors">
