---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import FloatingHero from '~/components/widgets/FloatingHero.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import BeforeAfterSlider from '~/components/widgets/BeforeAfterSlider.astro';
import { Image } from 'astro:assets';
import { testimonials } from '~/data/testimonials';
import { getPermalink } from '~/utils/permalinks';

import beforeImage from '~/assets/images/slider - crashed to fixed/unfallschaden.webp';
import afterImage from '~/assets/images/slider - crashed to fixed/repariert.webp';
import gutachtenImage from '~/assets/images/008.webp';
import ansprücheImage from '~/assets/images/Fahrzeuginspektion.webp';
import logoImage from '~/assets/images/logo.webp';

const metadata = {
  title: 'KFZ Gutachter Remscheid & KFZ Sachverständiger Unfallgutachten bei SchadenCheck',
  description:
    'KFZ Gutachter & Sachverständiger Remscheid. Kostenloses Unfallgutachten bei Haftpflichtschäden. Vor-Ort-Begutachtung in 24-48h. Unabhängig & rechtssicher.',
  canonical: 'https://schaden-check24.de/',
  ignoreTitleTemplate: true,
  openGraph: {
    type: 'website',
    url: 'https://schaden-check24.de/',
    title: 'KFZ Gutachter Remscheid & KFZ Sachverständiger Unfallgutachten bei SchadenCheck',
    description:
      'KFZ Gutachter Remscheid & KFZ Sachverständiger Unfallgutachten bei SchadenCheck – Kostenloses Unfallgutachten in 24h',
    siteName: 'KFZ Gutachter Remscheid & KFZ Sachverständiger Unfallgutachten bei SchadenCheck',
    locale: 'de_DE',
  },
};
---

<Layout metadata={metadata}>
  <!-- Floating Hero Section ******************* -->

  <FloatingHero
    title="<span class='text-highlight'>Kfz Gutachter Remscheid</span> – Ihr Sachverständiger für Unfallgutachten"
    subtitle="Jetzt Schaden melden – Begutachtung innerhalb von 24 Stunden · Unabhängig · Rechtssicher"
  />

  <!-- Combined Steps + Slider Section *************** -->
  <section class="py-16 md:py-20 relative overflow-hidden dark:from-slate-900 dark:via-slate-800 dark:to-slate-700" style="background: linear-gradient(to bottom, #020f14 0%, #020f14 8%, #ffffff 34%, #ffffff 60%, #ffffff 75%, #ffffff 100%);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <!-- Section Header -->
      <div class="text-center mb-16 md:mb-20 pt-8 md:pt-12">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-4 text-highlight dark:text-white animate-on-scroll slide-up">
          So einfach geht's – in 3 Schritten
        </h2>
        <p class="text-lg text-gray-900 dark:text-white/80 max-w-3xl mx-auto animate-on-scroll slide-up delay-100">
          Dein KFZ Gutachten - Von der Schadensmeldung bis zur vollständigen Regulierung – wir begleiten Sie durch den gesamten Prozess.
        </p>
      </div>

      <!-- Grid: Steps + Slider -->
      <div class="grid md:grid-cols-2 gap-8 lg:gap-12 items-center">
        <!-- Left: Steps with connecting line -->
        <div class="relative">
          <!-- Vertical connecting line (connects icons, cut at top and bottom) -->
          <div class="absolute left-6 w-0.5 bg-highlight/30 dark:bg-gray-700 hidden sm:block" style="top: 3rem; height: calc(100% - 9rem);"></div>

          <div class="space-y-8">
            <!-- Step 1 -->
            <div class="flex gap-4 relative animate-on-scroll slide-right">
              <div class="flex-shrink-0 relative z-10">
                <div class="flex items-center justify-center w-12 h-12 rounded-full bg-brand text-white">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                  </svg>
                </div>
              </div>
              <div>
                <h3 class="text-xl md:text-2xl font-bold mb-2 text-brand dark:text-white">
                  1. Schaden melden
                </h3>
                <p class="text-gray-900 dark:text-white/70">
                  Rufen Sie uns an, schreiben Sie per WhatsApp oder nutzen Sie unser Online-Formular. Wir sind sofort für Sie da.
                </p>
              </div>
            </div>

            <!-- Step 2 -->
            <div class="flex gap-4 relative animate-on-scroll slide-right delay-100">
              <div class="flex-shrink-0 relative z-10">
                <div class="flex items-center justify-center w-12 h-12 rounded-full bg-brand text-white">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  </svg>
                </div>
              </div>
              <div>
                <h3 class="text-xl md:text-2xl font-bold mb-2 text-brand dark:text-white">
                  2. Vor-Ort-Begutachtung
                </h3>
                <p class="text-gray-900 dark:text-white/70">
                  Unsere Sachverständigen kommen zu Ihnen – ob zuhause, am Arbeitsplatz oder in der Werkstatt. Wir dokumentieren den Schaden professionell und erstellen Fotos.
                </p>
              </div>
            </div>

            <!-- Step 3 -->
            <div class="flex gap-4 relative animate-on-scroll slide-right delay-200">
              <div class="flex-shrink-0 relative z-10">
                <div class="flex items-center justify-center w-12 h-12 rounded-full bg-brand text-white">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 3v4a1 1 0 0 0 1 1h4"></path>
                    <path d="M5 8v-3a2 2 0 0 1 2 -2h7l5 5v11a2 2 0 0 1 -2 2h-5"></path>
                    <circle cx="6" cy="14" r="3"></circle>
                    <path d="M4.5 17l-1.5 5l3 -1.5l3 1.5l-1.5 -5"></path>
                  </svg>
                </div>
              </div>
              <div>
                <h3 class="text-xl md:text-2xl font-bold mb-2 text-brand dark:text-white">
                  3. Gutachten & Regulierung
                </h3>
                <p class="text-gray-900 dark:text-white/70">
                  Sie erhalten Ihr detailliertes Gutachten. Wir kümmern uns um die Kommunikation mit der Versicherung und unsere Partneranwälte setzen Ihre Ansprüche durch.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Before/After Slider -->
        <div class="order-first md:order-last animate-on-scroll slide-left">
          <BeforeAfterSlider
            beforeImage={beforeImage}
            afterImage={afterImage}
            beforeAlt="Unfallschaden am Fahrzeug mit Kfz Gutachter Remscheid und KFZ Sachverständiger Remscheid für Unfallgutachten"
            afterAlt="Repariertes Fahrzeug nach Gutachten vom Kfz Gutachter Remscheid und KFZ Sachverständiger Remscheid für Wertgutachten"
          />
          <p class="text-center text-sm text-gray-900 dark:text-white/60 mt-4">
            Von der Schadensdokumentation bis zur erfolgreichen Reparatur
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials Widget *************** -->

  <Testimonials
    title="Das sagen unsere Kunden"
    testimonials={testimonials}
  />

  <!-- Ansprüche nach einem Unfall *************** -->
  <section class="py-16 md:py-20 bg-white dark:bg-slate-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <!-- Section Header -->
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-4 text-brand dark:text-white animate-on-scroll slide-up">
          Ihre Ansprüche nach einem Unfall – das steht Ihnen wirklich zu
        </h2>
      </div>

      <!-- Grid: Image left, Cards right -->
      <div class="grid lg:grid-cols-12 gap-8 items-start">
        <!-- Left: Image -->
        <div class="lg:col-span-5 animate-on-scroll slide-right">
          <div class="sticky top-8">
            <Image
              src={ansprücheImage}
              alt="Kfz Gutachter Remscheid bei der professionellen Schadensbewertung für Unfallgutachten und Wertgutachten"
              class="rounded-2xl shadow-2xl w-full h-auto"
              widths={[400, 600, 800]}
              sizes="(max-width: 1024px) 100vw, 40vw"
              loading="lazy"
            />
          </div>
        </div>

        <!-- Right: Cards -->
        <div class="lg:col-span-7 grid gap-4">
        <!-- Card 1: Mobil bleiben -->
        <div
          class="group bg-gradient-to-br from-[#003366] to-[#002952] dark:from-[#003366] dark:to-[#001a33] border-2 border-[#003366] hover:border-[#7DD3E8] rounded-xl p-4 md:p-5 hover:shadow-xl transition-all duration-300 hover:-translate-y-1 animate-on-scroll slide-left"
        >
          <div class="flex items-start gap-3">
            <div class="flex-shrink-0">
              <svg
                class="w-6 h-6 text-highlight"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                ></path>
              </svg>
            </div>
            <div>
              <h3 class="text-lg md:text-xl font-bold text-white mb-2">
                Mobil bleiben – auch ohne eigenes Fahrzeug
              </h3>
              <p class="text-sm text-white/90">
                Ob Mietwagen oder Nutzungsausfall: Sie haben Anspruch darauf, mobil zu bleiben, solange Ihr Fahrzeug
                nicht genutzt werden kann. Die Kosten trägt die Versicherung des Verursachers.
              </p>
            </div>
          </div>
        </div>

        <!-- Card 2: Wertverlust -->
        <div
          class="group bg-gradient-to-br from-[#003366] to-[#002952] dark:from-[#003366] dark:to-[#001a33] border-2 border-[#003366] hover:border-[#7DD3E8] rounded-xl p-4 md:p-5 hover:shadow-xl transition-all duration-300 hover:-translate-y-1 animate-on-scroll slide-left delay-100"
        >
          <div class="flex items-start gap-3">
            <div class="flex-shrink-0">
              <svg
                class="w-6 h-6 text-highlight"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                ></path>
              </svg>
            </div>
            <div>
              <h3 class="text-lg md:text-xl font-bold text-white mb-2">
                Ausgleich für den Wertverlust Ihres Autos
              </h3>
              <p class="text-sm text-white/90">
                Selbst nach einer fachgerechten Reparatur bleibt ein Unfallschaden wertmindernd. Diese Differenz wird
                Ihnen als <a href={getPermalink('/blog/wertminderung-nach-unfall/')} class="underline hover:text-highlight">merkantile Wertminderung</a> ausgezahlt – und zwar zusätzlich zur Reparatur.
              </p>
            </div>
          </div>
        </div>

        <!-- Card 3: Reparatur oder Auszahlung -->
        <div
          class="group bg-gradient-to-br from-[#003366] to-[#002952] dark:from-[#003366] dark:to-[#001a33] border-2 border-[#003366] hover:border-[#7DD3E8] rounded-xl p-4 md:p-5 hover:shadow-xl transition-all duration-300 hover:-translate-y-1 animate-on-scroll slide-left delay-200"
        >
          <div class="flex items-start gap-3">
            <div class="flex-shrink-0">
              <svg
                class="w-6 h-6 text-highlight"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                ></path>
              </svg>
            </div>
            <div>
              <h3 class="text-lg md:text-xl font-bold text-white mb-2">
                Sie entscheiden: Reparatur oder Auszahlung
              </h3>
              <p class="text-sm text-white/90">
                Niemand kann Sie zur Reparatur zwingen. Auf Wunsch lassen Sie sich den errechneten Schaden einfach
                auszahlen („fiktive Abrechnung") – flexibel, unkompliziert, rechtssicher.
              </p>
            </div>
          </div>
        </div>

        <!-- Card 4: Abschleppkosten -->
        <div
          class="group bg-gradient-to-br from-[#003366] to-[#002952] dark:from-[#003366] dark:to-[#001a33] border-2 border-[#003366] hover:border-[#7DD3E8] rounded-xl p-4 md:p-5 hover:shadow-xl transition-all duration-300 hover:-translate-y-1 animate-on-scroll slide-left delay-300"
        >
          <div class="flex items-start gap-3">
            <div class="flex-shrink-0">
              <svg
                class="w-6 h-6 text-highlight"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                ></path>
              </svg>
            </div>
            <div>
              <h3 class="text-lg md:text-xl font-bold text-white mb-2">
                Abschleppkosten? Kein Thema.
              </h3>
              <p class="text-sm text-white/90">
                Wenn Ihr Fahrzeug nicht mehr fahrbereit war, werden die Kosten für den Abschleppdienst von der
                gegnerischen Versicherung vollständig übernommen.
              </p>
            </div>
          </div>
        </div>

        <!-- Card 5: Gutachten kostenlos -->
        <div
          class="group bg-gradient-to-br from-[#7DD3E8] to-[#5ec4de] border-2 border-[#7DD3E8] hover:border-[#003366] rounded-xl p-4 md:p-5 hover:shadow-xl transition-all duration-300 hover:-translate-y-1 animate-on-scroll slide-left delay-400"
        >
          <div class="flex items-start gap-3">
            <div class="flex-shrink-0">
              <svg
                class="w-6 h-6 text-brand"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                ></path>
              </svg>
            </div>
            <div class="flex-1">
              <h3 class="text-lg md:text-xl font-bold text-brand mb-2">
                Ihr Gutachten – für Sie kostenlos
              </h3>
              <p class="text-sm text-brand/90">
                Bei einem unverschuldeten Unfall trägt die gegnerische Versicherung die Kosten für das Gutachten. Sie
                zahlen keinen Cent – wir kümmern uns um alles.
              </p>
            </div>
          </div>
        </div>

        <!-- CTA Buttons (separate, außerhalb der Box) -->
        <div class="grid sm:grid-cols-2 gap-4 mt-2 animate-on-scroll slide-up delay-500">
          <a
            href="tel:+4921917932020"
            class="btn-primary-brand inline-flex items-center justify-center py-3.5 sm:py-4 px-6 rounded-xl font-bold text-base transition-all hover:shadow-2xl hover:-translate-y-1 min-h-[52px] sm:min-h-[56px]"
            data-analytics="phone_click"
          >
            <svg class="w-6 h-6 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              ></path>
            </svg>
            Jetzt anrufen
          </a>
          <a
            href="https://wa.me/4921917932020?text=Hallo%2C%20ich%20m%C3%B6chte%20ein%20kostenloses%20Gutachten%20anfragen."
            target="_blank"
            rel="noopener noreferrer"
            class="btn-whatsapp inline-flex items-center justify-center py-3.5 sm:py-4 px-6 rounded-xl font-bold text-base transition-all hover:shadow-2xl hover:-translate-y-1 min-h-[52px] sm:min-h-[56px]"
            data-analytics="whatsapp_click"
          >
            <svg class="w-6 h-6 mr-3" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
              ></path>
            </svg>
            WhatsApp
          </a>
        </div>
        </div>
    </div>
  </section>

  <!-- USP-Leiste (Ihre Vorteile) *************** -->
  <section class="py-12 md:py-16 bg-gradient-to-b from-white via-[#E5F6F9] to-[#7DD3E8]/30 dark:from-slate-900 dark:via-slate-800 dark:to-slate-700 relative overflow-hidden">

    <div class="max-w-7xl mx-auto px-4 sm:px-6 relative z-10">
      <p class="text-center text-brand dark:text-highlight font-semibold text-sm uppercase tracking-wider mb-6 animate-on-scroll slide-up">Ihre Vorteile</p>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
        <!-- Vorteil 1: Kostenlos -->
        <div class="flex flex-col items-center text-center group animate-on-scroll slide-up delay-100">
          <div class="w-16 h-16 md:w-20 md:h-20 rounded-full bg-brand/5 dark:bg-white/10 backdrop-blur-sm flex items-center justify-center mb-4 group-hover:bg-brand/10 dark:group-hover:bg-white/20 transition-all duration-300 group-hover:scale-110">
            <svg class="w-8 h-8 md:w-10 md:h-10 text-brand dark:text-highlight" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              <line x1="4" y1="4" x2="20" y2="20" stroke="currentColor" stroke-width="2" stroke-linecap="round"></line>
            </svg>
          </div>
          <h3 class="text-brand dark:text-highlight font-bold text-lg md:text-xl mb-2">Kostenlos*</h3>
          <p class="text-gray-600 dark:text-highlight/70 text-sm">Bei Haftpflichtschäden für Sie kostenfrei</p>
        </div>

        <!-- Vorteil 2: Schnell vor Ort -->
        <div class="flex flex-col items-center text-center group animate-on-scroll slide-up delay-200">
          <div class="w-16 h-16 md:w-20 md:h-20 rounded-full bg-brand/5 dark:bg-white/10 backdrop-blur-sm flex items-center justify-center mb-4 group-hover:bg-brand/10 dark:group-hover:bg-white/20 transition-all duration-300 group-hover:scale-110">
            <svg class="w-8 h-8 md:w-10 md:h-10 text-brand dark:text-highlight" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-brand dark:text-highlight font-bold text-lg md:text-xl mb-2">Schnell vor Ort</h3>
          <p class="text-gray-600 dark:text-highlight/70 text-sm">Begutachtung innerhalb von 24-48 Stunden</p>
        </div>

        <!-- Vorteil 3: Unabhängig -->
        <div class="flex flex-col items-center text-center group animate-on-scroll slide-up delay-300">
