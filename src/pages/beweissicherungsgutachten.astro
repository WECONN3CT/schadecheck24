---
import Layout from '~/layouts/PageLayout.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { testimonials } from '~/data/testimonials';

const metadata = {
  title:
    'Beweissicherungsgutachten Remscheid | KFZ Gutachter Remscheid & KFZ Sachverständiger Unfallgutachten bei SchadenCheck',
  description:
    'Beweissicherungsgutachten Remscheid – rechtssichere Dokumentation für Versicherung & Gericht. KFZ Gutachter vor Ort in Remscheid, Solingen & Wuppertal.',
  canonical: 'https://schaden-check24.de/beweissicherungsgutachten/',
};
---

<Layout metadata={metadata}>
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-b from-white to-gray-50 dark:from-slate-900 dark:to-slate-800 py-8 sm:py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-4xl mx-auto">
        <p class="text-sm sm:text-base text-brand dark:text-blue-200 font-bold tracking-wide uppercase mb-2">
          Beweise sichern
        </p>
        <h1 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold mb-4 text-brand dark:text-white leading-tight px-2">
          Beweissicherungsgutachten
        </h1>
        <p class="text-base sm:text-lg md:text-xl text-gray-600 dark:text-gray-300 mb-6 sm:mb-8 px-2">
          Nach einem Unfall oder Schaden ist schnelles Handeln wichtig. Ein Beweissicherungsgutachten dokumentiert den Schaden umfassend und rechtssicher – als Grundlage für spätere Ansprüche.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="tel:+4921917932020"
            class="btn-primary-brand inline-flex items-center justify-center py-3 px-6 text-lg rounded-xl font-bold"
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            Jetzt anrufen
          </a>
          <a
            href="https://wa.me/4921917932020?text=Hallo%2C%20ich%20benötige%20ein%20Beweissicherungsgutachten."
            target="_blank"
            rel="noopener noreferrer"
            class="btn-whatsapp inline-flex items-center justify-center py-3 px-6 text-lg rounded-xl font-bold"
          >
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path>
            </svg>
            WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Vorteile -->
  <Features3
    title="Warum Beweissicherung wichtig ist"
    subtitle="Schützen Sie Ihre Rechte mit professioneller Dokumentation"
    columns={2}
    items={[
      {
        title: 'Rechtssicherheit',
        description: 'Gerichtsfeste Dokumentation des Schadenshergangs und Fahrzeugzustands.',
        icon: 'tabler:gavel',
      },
      {
        title: 'Zeitnahe Erfassung',
        description: 'Sofortige Sicherung aller relevanten Beweise direkt nach dem Vorfall.',
        icon: 'tabler:clock-check',
      },
      {
        title: 'Umfassende Fotos',
        description: 'Detaillierte Fotodokumentation aus allen relevanten Perspektiven.',
        icon: 'tabler:camera',
      },
      {
        title: 'Neutral & Unabhängig',
        description: 'Objektive Bewertung ohne Interessenkonflikt mit Versicherungen.',
        icon: 'tabler:scale',
      },
    ]}
  />

  <!-- Testimonials -->
  <Testimonials
    title="Das sagen unsere Kunden"
    testimonials={testimonials}
  />

  <!-- Wann ist Beweissicherung sinnvoll? -->
  <section class="bg-neutral py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12 animate-on-scroll slide-up">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-brand dark:text-white mb-4 px-2 leading-tight">
          Wann ist ein Beweissicherungsgutachten notwendig?
        </h2>
        <p class="text-lg sm:text-xl text-gray-600 dark:text-gray-400 max-w-3xl mx-auto px-4">
          Situationen, in denen schnelles Handeln entscheidend ist
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-white dark:bg-slate-800 rounded-2xl p-8 shadow-lg animate-on-scroll slide-right">
          <div class="w-16 h-16 bg-gradient-to-br from-[#7DD3E8] to-[#003366] rounded-xl flex items-center justify-center mb-6">
            <span class="text-4xl">⚠️</span>
          </div>
          <h3 class="text-xl sm:text-2xl font-bold mb-4 text-brand dark:text-white">Typische Anwendungsfälle</h3>
          <ul class="space-y-3 text-gray-600 dark:text-gray-400">
            <li class="flex items-start">
              <svg class="w-6 h-6 text-[#7DD3E8] mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Unfallschäden mit unklarem Hergang</span>
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-[#7DD3E8] mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Verdeckte Schäden (z.B. Hagelschaden)</span>
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-[#7DD3E8] mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Vandalismusschäden</span>
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-[#7DD3E8] mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Schäden vor geplanter Reparatur</span>
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-[#7DD3E8] mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Streitige Schadensfälle</span>
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-[#7DD3E8] mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Fahrzeugrücknahme nach Leasingende</span>
            </li>
          </ul>
        </div>

        <div class="bg-white dark:bg-slate-800 rounded-2xl p-8 shadow-lg animate-on-scroll slide-left">
          <div class="w-16 h-16 bg-gradient-to-br from-[#003366] to-[#7DD3E8] rounded-xl flex items-center justify-center mb-6">
            <span class="text-4xl">📋</span>
          </div>
          <h3 class="text-xl sm:text-2xl font-bold mb-4 text-brand dark:text-white">Was wird dokumentiert?</h3>
          <ul class="space-y-3 text-gray-600 dark:text-gray-400">
            <li class="flex items-start">
              <svg class="w-6 h-6 text-[#7DD3E8] mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Schadensbild mit Detailaufnahmen</span>
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-[#7DD3E8] mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Fahrzeugzustand vor und nach Vorfall</span>
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-[#7DD3E8] mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Unfallort und Rahmenbedingungen</span>
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-[#7DD3E8] mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Technische Fahrzeugdaten</span>
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-[#7DD3E8] mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Alle sichtbaren Beschädigungen</span>
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-[#7DD3E8] mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Kilometerstand und Ausstattung</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Der Unterschied zum normalen Gutachten -->
  <section class="py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12 animate-on-scroll slide-up">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-brand dark:text-white mb-4 px-2 leading-tight">
          Beweissicherung vs. Vollgutachten
        </h2>
        <p class="text-base sm:text-lg md:text-xl text-gray-600 dark:text-gray-400 px-2">
          Worin liegt der Unterschied?
        </p>
      </div>

      <div class="bg-white dark:bg-slate-800 rounded-2xl p-8 md:p-12 shadow-xl animate-on-scroll slide-up">
        <div class="space-y-6 text-gray-600 dark:text-gray-400">
          <p class="text-lg">
            Ein <strong class="text-brand dark:text-white">Beweissicherungsgutachten</strong> fokussiert sich auf die
            <strong class="text-brand dark:text-white">zeitnahe Dokumentation</strong> des Ist-Zustands direkt nach
            dem Schadenereignis. Es dient als Beweismittel für spätere Verfahren.
          </p>
          <p class="text-lg">
            Ein <strong class="text-brand dark:text-white">Vollgutachten</strong> (Schadensgutachten) geht darüber
            hinaus und beinhaltet eine detaillierte Schadenskalkulation, Reparaturkostenaufstellung und
            Wertermittlung zur direkten Schadenregulierung.
          </p>
          <div class="bg-[#7DD3E8]/10 border-l-4 border-[#7DD3E8] p-6 rounded-r-lg mt-6">
            <p class="text-brand dark:text-white font-semibold">
              ℹ️ Tipp: Bei unklaren Schadensfällen empfehlen wir die Beweissicherung als ersten Schritt. Später
              kann bei Bedarf ein Vollgutachten folgen.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Regional-Bezug -->
  <section class="py-16 md:py-20 bg-white dark:bg-slate-900">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-brand dark:text-white mb-4">
          Schnelle Beweissicherung in Remscheid und Umgebung
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-400">
          Professionelle Schadensdokumentation im Bergischen Land
        </p>
      </div>

      <div class="prose prose-lg dark:prose-invert mx-auto">
        <p>
          Bei Unfällen, Vandalismus oder strittigen Schadensfällen ist schnelles Handeln entscheidend. Als Kfz-Sachverständiger in <strong>Remscheid</strong> bieten wir Ihnen professionelle Beweissicherungsgutachten, die den Zustand Ihres Fahrzeugs umfassend und rechtssicher dokumentieren – als gerichtsfeste Grundlage für spätere Ansprüche oder Verfahren.
        </p>

        <p>
          Im <strong>Bergischen Land</strong> – von <strong>Wuppertal</strong> über <strong>Solingen</strong> bis nach <strong>Leverkusen</strong> – sind wir Ihr schneller Partner, wenn es um die Sicherung von Beweisen geht. Zeit ist bei der Beweissicherung oft der entscheidende Faktor: Spuren können verloren gehen, Schäden sich verändern, oder das Fahrzeug wird bereits repariert. Deshalb sind wir in der Regel bereits innerhalb von 24 Stunden bei Ihnen vor Ort.
        </p>

        <p>
          Wir kommen direkt zu Ihnen – ob nach Hause, zur Werkstatt oder zum Unfallort in <strong>Remscheid</strong> und ganz <strong>NRW</strong>. Die Beweissicherung umfasst detaillierte Fotodokumentation, Schadensbeschreibung und technische Datenerfassung. Sie erhalten ein rechtssicheres Gutachten, das bei Versicherungen, Gerichten und Behörden volle Anerkennung findet. Kontaktieren Sie uns noch heute – bei Beweissicherung zählt jede Stunde!
        </p>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="py-16 md:py-20 bg-gradient-to-b from-gray-50 to-white dark:from-slate-800 dark:to-slate-900">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-brand dark:text-white mb-4">
          Häufig gestellte Fragen
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-400">
          Alles Wichtige zur Beweissicherung
        </p>
      </div>

      <div class="space-y-4">
        <details class="group bg-white dark:bg-slate-800 rounded-lg border border-gray-200 dark:border-slate-700 overflow-hidden">
          <summary class="flex justify-between items-center cursor-pointer px-6 py-4 font-semibold text-brand dark:text-white hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors">
            <span>Wann ist ein Beweissicherungsgutachten notwendig?</span>
            <svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="px-6 pb-6 text-gray-600 dark:text-gray-400">
            <p>
              Ein Beweissicherungsgutachten ist immer dann wichtig, wenn <strong>Beweise schnell gesichert werden müssen</strong> oder der Schadenshergang unklar ist. Typische Fälle: <strong>Unfälle mit Fahrerflucht</strong>, <strong>Vandalismus oder Diebstahlschäden</strong>, <strong>Hagelschäden</strong>, <strong>streitige Unfallhergänge</strong>, <strong>versteckte Schäden</strong> nach Unfall, <strong>Fahrzeugrückgabe nach Leasing</strong>, oder wenn Sie das Fahrzeug bereits reparieren möchten, aber die Beweise sichern wollen. Die Beweissicherung dokumentiert den Ist-Zustand objektiv und unabhängig – bevor sich etwas verändert oder Spuren verloren gehen.
            </p>
          </div>
        </details>

        <details class="group bg-white dark:bg-slate-800 rounded-lg border border-gray-200 dark:border-slate-700 overflow-hidden">
          <summary class="flex justify-between items-center cursor-pointer px-6 py-4 font-semibold text-brand dark:text-white hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors">
            <span>Was ist der Unterschied zu einem normalen Schadensgutachten?</span>
            <svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="px-6 pb-6 text-gray-600 dark:text-gray-400">
            <p>
              Ein <strong>Beweissicherungsgutachten</strong> konzentriert sich auf die <strong>zeitnahe, umfassende Dokumentation</strong> des Fahrzeugzustands und Schadensbilds. Es sichert Beweise und dient als Grundlage für spätere rechtliche Schritte oder Verhandlungen. Ein <strong>Schadensgutachten</strong> (Vollgutachten) geht darüber hinaus und berechnet detailliert die Reparaturkosten, ermittelt die Wertminderung und dient der direkten Schadenregulierung mit der Versicherung. Bei unklaren Fällen empfiehlt sich oft zuerst die Beweissicherung – diese kann später bei Bedarf zu einem Vollgutachten erweitert werden, wenn die Regulierung ansteht.
            </p>
          </div>
        </details>

        <details class="group bg-white dark:bg-slate-800 rounded-lg border border-gray-200 dark:border-slate-700 overflow-hidden">
          <summary class="flex justify-between items-center cursor-pointer px-6 py-4 font-semibold text-brand dark:text-white hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors">
            <span>Wie schnell muss die Beweissicherung erfolgen?</span>
            <svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="px-6 pb-6 text-gray-600 dark:text-gray-400">
            <p>
              Bei der Beweissicherung gilt: <strong>Je schneller, desto besser!</strong> Idealerweise sollte die Dokumentation <strong>innerhalb von 24-48 Stunden</strong> nach dem Schadenereignis erfolgen. Der Grund: Spuren können verblassen, Wetterbedingungen ändern sich, das Fahrzeug wird bewegt oder repariert, oder Zeugen erinnern sich nicht mehr genau. Bei <strong>Vandalismus, Unfallschäden oder Hagelschäden</strong> ist sofortige Beweissicherung besonders wichtig. Wir sind in der Regel bereits am nächsten Werktag bei Ihnen vor Ort. Bei besonders dringenden Fällen (z.B. drohendes Fahrzeug-Abschleppen) auch am selben Tag. Kontaktieren Sie uns sofort nach dem Schadenereignis!
            </p>
          </div>
        </details>

        <details class="group bg-white dark:bg-slate-800 rounded-lg border border-gray-200 dark:border-slate-700 overflow-hidden">
          <summary class="flex justify-between items-center cursor-pointer px-6 py-4 font-semibold text-brand dark:text-white hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors">
            <span>Was kostet ein Beweissicherungsgutachten?</span>
            <svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="px-6 pb-6 text-gray-600 dark:text-gray-400">
            <p>
              Die Kosten für ein Beweissicherungsgutachten hängen vom Umfang der Dokumentation ab. In der Regel liegen die Kosten zwischen <strong>300 und 600 Euro</strong>, je nach Aufwand und Fahrzeugtyp. Bei <strong>unverschuldeten Unfällen</strong> trägt die <strong>Haftpflichtversicherung des Unfallverursachers</strong> die Kosten – das Gutachten ist für Sie kostenfrei. Bei eigenverschuldeten oder strittigen Fällen können Sie die Kosten zunächst selbst tragen und später im Rahmen der Schadenregulierung geltend machen. Auch bei <strong>Kaskoschäden</strong> (Hagel, Vandalismus) übernimmt meist Ihre eigene Versicherung die Gutachterkosten. Wir beraten Sie gerne vorab über Kostenübernahme und Erstattungsmöglichkeiten.
            </p>
          </div>
        </details>

        <details class="group bg-white dark:bg-slate-800 rounded-lg border border-gray-200 dark:border-slate-700 overflow-hidden">
          <summary class="flex justify-between items-center cursor-pointer px-6 py-4 font-semibold text-brand dark:text-white hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors">
            <span>Ist das Beweissicherungsgutachten vor Gericht verwendbar?</span>
            <svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="px-6 pb-6 text-gray-600 dark:text-gray-400">
            <p>
