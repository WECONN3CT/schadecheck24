---
import Layout from '~/layouts/PageLayout.astro';
import { Image } from 'astro:assets';

const metadata = {
  title: 'Kfz-Gutachten & Leistungen Remscheid',
  description: 'Professionelle Kfz-Gutachten für jeden Bedarf: Unfallgutachten, Wertgutachten, Schadensgutachten und mehr. Unabhängig, transparent und rechtssicher.',
  canonical: 'https://schaden-check24.de/leistungen/',
};
---

<Layout metadata={metadata}>
  <!-- Hero Section -->
  <section class="relative py-16 md:py-24 bg-gradient-to-b from-white via-[#E5F6F9] to-white dark:from-slate-900 dark:via-slate-800 dark:to-slate-900 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12 md:mb-16">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 text-brand dark:text-white animate-on-scroll slide-up">
          Kompetenz, Transparenz & Durchsetzungskraft
        </h1>
        <p class="text-xl md:text-2xl text-gray-700 dark:text-gray-300 mb-4 max-w-4xl mx-auto animate-on-scroll slide-up delay-100">
          Ihre starken Vorteile mit SchadenCheck
        </p>
        <p class="text-lg text-gray-600 dark:text-gray-400 max-w-3xl mx-auto animate-on-scroll slide-up delay-200">
          Unsere unabhängigen Kfz-Gutachten liefern Ihnen Klarheit, Sicherheit und eine solide Grundlage für die Regulierung Ihres Schadens.
          Ob Unfall, technischer Defekt oder Wertbestimmung – wir sorgen dafür, dass Sie wissen, was Ihr Fahrzeug wirklich wert ist, und dass Ihre Ansprüche vollständig anerkannt werden.
        </p>
      </div>

      <div class="bg-gradient-to-br from-[#7DD3E8]/20 to-[#003366]/10 dark:from-[#003366]/30 dark:to-[#7DD3E8]/10 rounded-2xl p-8 md:p-12 max-w-4xl mx-auto animate-on-scroll slide-up delay-300">
        <p class="text-lg text-gray-700 dark:text-gray-300 text-center">
          <strong>Wir übernehmen für Sie</strong> die gesamte Kommunikation mit Werkstatt und Versicherung, klären offene Fragen und sorgen für einen reibungslosen Ablauf – <strong>schnell, neutral und immer auf Ihrer Seite.</strong>
        </p>
      </div>
    </div>
  </section>

  <!-- Leistungen Grid -->
  <section class="py-16 md:py-20 bg-white dark:bg-slate-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">

        <!-- Leistung 1: Kurzgutachten -->
        <div class="group bg-white dark:bg-slate-800 rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 border-2 border-gray-100 hover:border-[#7DD3E8] dark:border-slate-700 dark:hover:border-[#7DD3E8] animate-on-scroll slide-up">
          <div class="w-16 h-16 bg-gradient-to-br from-[#7DD3E8] to-[#003366] rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
            <span class="text-4xl">⚙️</span>
          </div>
          <h3 class="text-2xl font-bold mb-4 text-brand dark:text-white">
            Kurzgutachten / Kosteneinschätzung
          </h3>
          <p class="text-gray-600 dark:text-gray-400 mb-6">
            Bei kleineren Schäden oder Parkremplern ist oft kein umfangreiches Gutachten nötig.
            Unser Kurzgutachten liefert eine schnelle, kompakte und kosteneffiziente Einschätzung – ideal zur Vorlage bei Versicherungen, Werkstätten oder für die private Dokumentation.
          </p>
          <a href="/kurzgutachten/" class="inline-flex items-center text-brand hover:text-[#7DD3E8] font-semibold transition-colors group">
            Zur Leistung
            <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
            </svg>
          </a>
        </div>

        <!-- Leistung 2: Wertgutachten -->
        <div class="group bg-white dark:bg-slate-800 rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 border-2 border-gray-100 hover:border-[#7DD3E8] dark:border-slate-700 dark:hover:border-[#7DD3E8] animate-on-scroll slide-up delay-100">
          <div class="w-16 h-16 bg-gradient-to-br from-[#7DD3E8] to-[#003366] rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
            <span class="text-4xl">💰</span>
          </div>
          <h3 class="text-2xl font-bold mb-4 text-brand dark:text-white">
            Wertgutachten
          </h3>
          <p class="text-gray-600 dark:text-gray-400 mb-6">
            Ein Wertgutachten bestimmt den tatsächlichen Marktwert Ihres Fahrzeugs – unabhängig, transparent und nachvollziehbar.
            Wir berücksichtigen Zustand, Laufleistung, Sonderausstattung und aktuelle Marktsituation. Ideal für Verkauf, Leasingrückgabe oder Versicherungseinstufung.
          </p>
          <a href="/wertgutachten/" class="inline-flex items-center text-brand hover:text-[#7DD3E8] font-semibold transition-colors group">
            Zur Leistung
            <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
            </svg>
          </a>
        </div>

        <!-- Leistung 3: Beweissicherungsgutachten -->
        <div class="group bg-white dark:bg-slate-800 rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 border-2 border-gray-100 hover:border-[#7DD3E8] dark:border-slate-700 dark:hover:border-[#7DD3E8] animate-on-scroll slide-up delay-200">
          <div class="w-16 h-16 bg-gradient-to-br from-[#7DD3E8] to-[#003366] rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
            <span class="text-4xl">📸</span>
          </div>
          <h3 class="text-2xl font-bold mb-4 text-brand dark:text-white">
            Beweissicherungsgutachten
          </h3>
          <p class="text-gray-600 dark:text-gray-400 mb-6">
            Wenn es auf Beweise ankommt, zählt Genauigkeit.
            Unser Beweissicherungsgutachten dokumentiert Schäden, Mängel oder Reparaturfehler neutral und gerichtsfest – optimal bei technischen Streitfällen, verdeckten Mängeln oder Auseinandersetzungen mit Händlern und Werkstätten.
          </p>
          <a href="/beweissicherungsgutachten/" class="inline-flex items-center text-brand hover:text-[#7DD3E8] font-semibold transition-colors group">
            Zur Leistung
            <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
            </svg>
          </a>
        </div>

        <!-- Leistung 4: Schadensgutachten -->
