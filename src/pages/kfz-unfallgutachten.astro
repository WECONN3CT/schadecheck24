---
import Layout from '~/layouts/PageLayout.astro';
import Features3 from '~/components/widgets/Features3.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import { testimonials } from '~/data/testimonials';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title:
    'Kfz Unfallgutachten Remscheid | KFZ Gutachter Remscheid & KFZ Sachverständiger Unfallgutachten bei SchadenCheck',
  description:
    'Unfallgutachten Remscheid – unabhängige Schadenbewertung, rechtssicher & anerkannt. Bei Haftpflichtschäden kostenfrei. Schnell vor Ort in NRW.',
  canonical: 'https://schaden-check24.de/kfz-unfallgutachten/',
};
---

<Layout metadata={metadata}>
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-b from-white to-gray-50 dark:from-slate-900 dark:to-slate-800 py-8 sm:py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-4xl mx-auto">
        <p class="text-sm sm:text-base text-brand dark:text-blue-200 font-bold tracking-wide uppercase mb-2">
          Nach dem Unfall
        </p>
        <h1 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold mb-4 text-brand dark:text-white leading-tight px-2">
          Kfz-Unfallgutachten
        </h1>
        <p class="text-base sm:text-lg md:text-xl text-gray-600 dark:text-gray-300 mb-6 sm:mb-8 px-2">
          Nach einem Verkehrsunfall benötigen Sie ein professionelles Unfallgutachten zur Schadenregulierung. Wir erstellen eine umfassende, rechtssichere Dokumentation – unabhängig, schnell und anerkannt.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="tel:+4921917932020" class="btn-primary-brand inline-flex items-center justify-center py-3 px-6 text-lg rounded-xl font-bold">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
            Jetzt anrufen
          </a>
          <a href="https://wa.me/4921917932020?text=Hallo%2C%20ich%20hatte%20einen%20Unfall%20und%20benötige%20ein%20Gutachten." target="_blank" rel="noopener noreferrer" class="btn-whatsapp inline-flex items-center justify-center py-3 px-6 text-lg rounded-xl font-bold">
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path></svg>
            WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Vorteile -->
  <Features3
    title="Warum ein professionelles Unfallgutachten?"
    subtitle="Ihre Vorteile bei der Schadenregulierung"
    columns={2}
    items={[
      {
        title: 'Rechtssicher',
        description: 'Gerichtsfest und von allen Versicherungen anerkannt.',
        icon: 'tabler:gavel',
      },
      {
        title: 'Unabhängig',
        description: 'Neutrale Bewertung ohne Bindung an Versicherungen oder Werkstätten.',
        icon: 'tabler:user-check',
      },
      {
        title: 'Bei Haftpflicht kostenfrei',
        description: 'Bei Haftpflichtschäden für Sie kostenfrei – die gegnerische Versicherung zahlt.',
        icon: 'tabler:receipt-off',
      },
      {
        title: 'Schnell vor Ort',
        description: 'Termin innerhalb von 24-48 Stunden – wir kommen zu Ihnen nach Hause oder ins Büro.',
        icon: 'tabler:clock',
      },
    ]}
  />

  <!-- Testimonials -->
  <Testimonials
    title="Das sagen unsere Kunden"
    testimonials={testimonials}
  />

  <!-- Wann benötigen Sie ein Unfallgutachten? -->
  <section class="bg-neutral py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12 animate-on-scroll slide-up">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-brand dark:text-white mb-4 px-2 leading-tight">
          Wann benötigen Sie ein Unfallgutachten?
        </h2>
        <p class="text-base sm:text-lg md:text-xl text-gray-600 dark:text-gray-400 max-w-3xl mx-auto px-4">
          In diesen Situationen ist ein professionelles Gutachten wichtig
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="bg-white dark:bg-slate-800 rounded-2xl p-6 shadow-lg animate-on-scroll slide-up delay-100">
          <div class="w-14 h-14 bg-gradient-to-br from-[#7DD3E8] to-[#003366] rounded-xl flex items-center justify-center mb-4">
            <span class="text-3xl">🚗</span>
          </div>
          <h3 class="text-lg font-bold mb-2 text-brand dark:text-white">Verkehrsunfall</h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm">
            Kollision mit anderen Fahrzeugen, Auffahrunfälle, Unfälle an Kreuzungen
          </p>
        </div>

        <div class="bg-white dark:bg-slate-800 rounded-2xl p-6 shadow-lg animate-on-scroll slide-up delay-200">
          <div class="w-14 h-14 bg-gradient-to-br from-[#003366] to-[#7DD3E8] rounded-xl flex items-center justify-center mb-4">
            <span class="text-3xl">💶</span>
          </div>
          <h3 class="text-lg font-bold mb-2 text-brand dark:text-white">Schaden über 750 EUR</h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm">
            Ab ca. 750 EUR Schadenhöhe lohnt sich ein Vollgutachten finanziell
          </p>
        </div>

        <div class="bg-white dark:bg-slate-800 rounded-2xl p-6 shadow-lg animate-on-scroll slide-up delay-300">
          <div class="w-14 h-14 bg-gradient-to-br from-[#7DD3E8] to-[#003366] rounded-xl flex items-center justify-center mb-4">
            <span class="text-3xl">📋</span>
          </div>
          <h3 class="text-lg font-bold mb-2 text-brand dark:text-white">Schadensregulierung</h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm">
            Wenn die Versicherung den Schaden regulieren soll – als Beweis und Grundlage
          </p>
        </div>

        <div class="bg-white dark:bg-slate-800 rounded-2xl p-6 shadow-lg animate-on-scroll slide-up delay-100">
          <div class="w-14 h-14 bg-gradient-to-br from-[#003366] to-[#7DD3E8] rounded-xl flex items-center justify-center mb-4">
            <span class="text-3xl">⚖️</span>
          </div>
          <h3 class="text-lg font-bold mb-2 text-brand dark:text-white">Streitige Fälle</h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm">
            Bei unklarer Schuldfrage oder Meinungsverschiedenheiten mit der Versicherung
          </p>
        </div>

        <div class="bg-white dark:bg-slate-800 rounded-2xl p-6 shadow-lg animate-on-scroll slide-up delay-200">
          <div class="w-14 h-14 bg-gradient-to-br from-[#7DD3E8] to-[#003366] rounded-xl flex items-center justify-center mb-4">
            <span class="text-3xl">🏛️</span>
          </div>
          <h3 class="text-lg font-bold mb-2 text-brand dark:text-white">Gerichtsverfahren</h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm">
            Als Beweismittel für Gerichtsverfahren und Rechtsstreitigkeiten
          </p>
        </div>

        <div class="bg-white dark:bg-slate-800 rounded-2xl p-6 shadow-lg animate-on-scroll slide-up delay-300">
          <div class="w-14 h-14 bg-gradient-to-br from-[#003366] to-[#7DD3E8] rounded-xl flex items-center justify-center mb-4">
            <span class="text-3xl">📉</span>
          </div>
          <h3 class="text-lg font-bold mb-2 text-brand dark:text-white">Wertminderung</h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm">
            Wenn Sie die merkantile Wertminderung geltend machen möchten
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Was beinhaltet das Unfallgutachten? -->
  <section class="py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12 animate-on-scroll slide-up">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-brand dark:text-white mb-4 px-2 leading-tight">
          Was beinhaltet ein Unfallgutachten?
        </h2>
        <p class="text-base sm:text-lg md:text-xl text-gray-600 dark:text-gray-400 px-2">
          Vollständige Dokumentation für optimale Schadenregulierung
        </p>
      </div>

      <div class="max-w-4xl mx-auto">
        <div class="bg-white dark:bg-slate-800 rounded-2xl p-8 md:p-12 shadow-xl animate-on-scroll slide-up">
          <ul class="space-y-4 text-gray-600 dark:text-gray-400">
            <li class="flex items-start">
              <svg class="w-6 h-6 text-[#7DD3E8] mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span><strong class="text-brand dark:text-white">Fahrzeugdaten:</strong> Marke, Modell, Kilometerstand, Erstzulassung, Ausstattung</span>
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-[#7DD3E8] mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span><strong class="text-brand dark:text-white">Unfallhergang:</strong> Dokumentation des Unfallgeschehens und der Beteiligten</span>
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-[#7DD3E8] mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span><strong class="text-brand dark:text-white">Schadensbeschreibung:</strong> Detaillierte Auflistung aller Beschädigungen</span>
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-[#7DD3E8] mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span><strong class="text-brand dark:text-white">Fotodokumentation:</strong> Umfassende Bildaufnahmen des Schadens aus allen Perspektiven</span>
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-[#7DD3E8] mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span><strong class="text-brand dark:text-white">Reparaturkalkulation:</strong> Detaillierte Kostenschätzung nach Herstellervorgaben</span>
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-[#7DD3E8] mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span><strong class="text-brand dark:text-white">Wiederbeschaffungswert:</strong> Aktueller Marktwert des Fahrzeugs vor dem Unfall</span>
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-[#7DD3E8] mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span><strong class="text-brand dark:text-white">Restwert:</strong> Verkaufswert des beschädigten Fahrzeugs (bei Totalschaden)</span>
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-[#7DD3E8] mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span><strong class="text-brand dark:text-white">Wertminderung:</strong> Merkantile Wertminderung durch Unfallhistorie</span>
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-[#7DD3E8] mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span><strong class="text-brand dark:text-white">Nutzungsausfall:</strong> Ausfallzeit für Ersatzfahrzeug oder Pauschale</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Der Ablauf -->
  <section class="bg-neutral py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12 animate-on-scroll slide-up">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-brand dark:text-white mb-4 px-2 leading-tight">
          So läuft die Begutachtung ab
        </h2>
        <p class="text-base sm:text-lg md:text-xl text-gray-600 dark:text-gray-400 px-2">
          Schnell, unkompliziert und transparent
        </p>
      </div>

      <div class="grid md:grid-cols-4 gap-6">
        <div class="text-center animate-on-scroll slide-up delay-100">
          <div class="w-20 h-20 bg-gradient-to-br from-[#7DD3E8] to-[#003366] rounded-full flex items-center justify-center mx-auto mb-6 text-white text-2xl font-bold">
            1
          </div>
          <h3 class="text-lg font-bold mb-3 text-brand dark:text-white">Kontaktaufnahme</h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm">
            Sie melden den Schaden telefonisch, per WhatsApp oder über unser Formular.
          </p>
        </div>

        <div class="text-center animate-on-scroll slide-up delay-200">
          <div class="w-20 h-20 bg-gradient-to-br from-[#003366] to-[#7DD3E8] rounded-full flex items-center justify-center mx-auto mb-6 text-white text-2xl font-bold">
            2
          </div>
          <h3 class="text-lg font-bold mb-3 text-brand dark:text-white">Terminvereinbarung</h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm">
            Wir vereinbaren einen Termin – innerhalb von 24-48 Stunden, wann es Ihnen passt.
          </p>
        </div>

        <div class="text-center animate-on-scroll slide-up delay-300">
          <div class="w-20 h-20 bg-gradient-to-br from-[#7DD3E8] to-[#003366] rounded-full flex items-center justify-center mx-auto mb-6 text-white text-2xl font-bold">
            3
          </div>
          <h3 class="text-lg font-bold mb-3 text-brand dark:text-white">Vor-Ort-Besichtigung</h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm">
            Wir kommen zu Ihnen und begutachten das Fahrzeug direkt vor Ort (ca. 30-45 Minuten).
          </p>
        </div>

        <div class="text-center animate-on-scroll slide-up delay-400">
          <div class="w-20 h-20 bg-gradient-to-br from-[#003366] to-[#7DD3E8] rounded-full flex items-center justify-center mx-auto mb-6 text-white text-2xl font-bold">
            4
          </div>
          <h3 class="text-lg font-bold mb-3 text-brand dark:text-white">Gutachten & Regulierung</h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm">
            Sie erhalten das fertige Gutachten digital – wir unterstützen Sie bei der Regulierung.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Regional-Bezug -->
  <section class="py-16 md:py-20 bg-white dark:bg-slate-900">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-brand dark:text-white mb-4">
          Kfz-Gutachter in Remscheid und Umgebung
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-400">
          Ihr zuverlässiger Partner für Unfallgutachten im Bergischen Land
        </p>
      </div>

      <div class="prose prose-lg dark:prose-invert mx-auto">
        <p>
          Als erfahrener Kfz-Sachverständiger in <strong>Remscheid</strong> sind wir Ihr kompetenter Ansprechpartner für professionelle Unfallgutachten.
          Unser Einzugsgebiet umfasst das gesamte <strong>Bergische Land</strong>, einschließlich <strong>Wuppertal</strong>, <strong>Solingen</strong>,
          <strong>Leverkusen</strong> und den angrenzenden Regionen in <strong>Nordrhein-Westfalen</strong>.
        </p>

        <p>
          Die zentrale Lage unseres Standorts in <strong>Remscheid, Kölner Str. 121</strong>, ermöglicht es uns, innerhalb von 24-48 Stunden
          bei Ihnen vor Ort zu sein – egal ob Sie in der Stadt oder im Umland wohnen. Wir kommen direkt zu Ihnen nach Hause,
          an Ihren Arbeitsplatz oder zur Werkstatt Ihrer Wahl.
        </p>

        <p>
          Unsere langjährige Erfahrung in der Region macht uns zu einem vertrauenswürdigen Partner für Versicherungen, Anwaltskanzleien
          und Privatpersonen. Wir kennen die lokalen Besonderheiten und arbeiten eng mit regionalen Werkstätten und Rechtsanwälten zusammen,
          um Ihnen den bestmöglichen Service zu bieten.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQs - Unfallgutachten -->
  <section class="py-16 md:py-20 bg-gradient-to-b from-gray-50 to-white dark:from-slate-800 dark:to-slate-900">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <p class="text-sm font-semibold text-highlight uppercase tracking-wider mb-2">FAQ</p>
        <h2 class="text-3xl md:text-4xl font-bold text-brand dark:text-white mb-4">
          Häufig gestellte Fragen zum Unfallgutachten
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-400">
          Antworten auf die wichtigsten Fragen rund um Kfz-Unfallgutachten
        </p>
      </div>

      <div class="space-y-4">
        <details class="group bg-white dark:bg-slate-800 rounded-lg border border-gray-200 dark:border-gray-700 transition-all duration-300">
          <summary class="flex justify-between items-center cursor-pointer p-6 hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors">
            <h3 class="text-xl font-bold text-brand dark:text-white">Wie läuft die Begutachtung ab?</h3>
            <svg class="w-6 h-6 text-highlight group-open:rotate-90 transition-transform duration-300 flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </summary>
          <div class="px-6 pb-6 text-gray-600 dark:text-gray-400">
            <p>Nach Ihrer Kontaktaufnahme vereinbaren wir einen Termin zur Vor-Ort-Begutachtung. Diese dauert ca. 30-45 Minuten. Wir dokumentieren alle Schäden detailliert mit Fotos, erfassen Fahrzeugdaten und erstellen eine umfassende Schadensanalyse. Das fertige Gutachten erhalten Sie digital innerhalb weniger Tage.</p>
          </div>
        </details>

        <details class="group bg-white dark:bg-slate-800 rounded-lg border border-gray-200 dark:border-gray-700 transition-all duration-300">
          <summary class="flex justify-between items-center cursor-pointer p-6 hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors">
            <h3 class="text-xl font-bold text-brand dark:text-white">Wie lange dauert die Gutachtenerstellung?</h3>
            <svg class="w-6 h-6 text-highlight group-open:rotate-90 transition-transform duration-300 flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </summary>
          <div class="px-6 pb-6 text-gray-600 dark:text-gray-400">
            <p>In der Regel erhalten Sie Ihr fertiges Gutachten innerhalb von 2-4 Werktagen nach der Begutachtung. Bei dringenden Fällen können wir das Gutachten auch schneller erstellen. Sie erhalten das Gutachten bequem per E-Mail als PDF-Datei.</p>
          </div>
        </details>

        <details class="group bg-white dark:bg-slate-800 rounded-lg border border-gray-200 dark:border-gray-700 transition-all duration-300">
