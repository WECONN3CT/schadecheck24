---
import Layout from '~/layouts/PageLayout.astro';
import Headline from '~/components/ui/Headline.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import { testimonials } from '~/data/testimonials';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'Kontakt | KFZ Gutachter Remscheid & KFZ Sachverständiger Unfallgutachten bei SchadenCheck',
  description:
    'Kontaktieren Sie KFZ Gutachter SchadenCheck für Ihre Fragen rund um Kfz-Gutachten und Unfallabwicklung.',
};
---

<Layout metadata={metadata}>
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-6xl">
    <div class="mb-8 md:mx-auto md:mb-12 text-center max-w-3xl">
      <h1 class="text-4xl md:text-5xl font-bold leading-tighter tracking-tighter font-heading text-heading mb-4">
        Kontakt
      </h1>
      <p class="mt-4 text-muted text-xl">Haben Sie Fragen? Wir sind für Sie da – persönlich, schnell und unkompliziert.</p>
    </div>

    <div class="grid md:grid-cols-2 gap-8 lg:gap-12">
      <!-- Kontaktinformationen -->
      <div class="space-y-8">
        <!-- Adresse -->
        <div class="bg-white dark:bg-slate-800 rounded-lg shadow-lg p-6">
          <h3 class="text-xl font-bold text-brand dark:text-white mb-4 flex items-center">
            <svg class="w-6 h-6 mr-3 text-highlight" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            Unser Standort
          </h3>
          <div class="text-gray-700 dark:text-gray-300 space-y-2">
            <p class="font-semibold">KFZ Sachverständigenbüro SchadenCheck</p>
            <p>Kölner Str. 121</p>
            <p>42897 Remscheid</p>
            <p class="text-sm text-gray-600 dark:text-gray-400 mt-4">
              Wir kommen auch zu Ihnen – ob zu Hause, am Arbeitsplatz oder in der Werkstatt.
            </p>
          </div>
        </div>

        <!-- Telefon -->
        <div class="bg-white dark:bg-slate-800 rounded-lg shadow-lg p-6">
          <h3 class="text-xl font-bold text-brand dark:text-white mb-4 flex items-center">
            <svg class="w-6 h-6 mr-3 text-highlight" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              ></path>
            </svg>
            Telefon
          </h3>
          <div class="space-y-3">
            <a
              href="tel:+4921917932020"
              class="block text-lg font-semibold text-brand hover:text-highlight transition-colors"
              data-analytics="phone_click"
            >
              +49 2191 7932020
            </a>
            <p class="text-sm text-gray-600 dark:text-gray-400">Montag - Sonntag: 00:00 - 24:00 Uhr</p>
            <p class="text-sm text-gray-600 dark:text-gray-400">Notfälle: 24/7 erreichbar</p>
          </div>
        </div>

        <!-- WhatsApp & E-Mail -->
        <div class="bg-white dark:bg-slate-800 rounded-lg shadow-lg p-6">
          <h3 class="text-xl font-bold text-brand dark:text-white mb-4 flex items-center">
            <svg class="w-6 h-6 mr-3 text-highlight" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"
              ></path>
            </svg>
            Weitere Kontaktmöglichkeiten
          </h3>
          <div class="space-y-4">
            <div>
              <p class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">WhatsApp</p>
              <a
                href="https://wa.me/4921917932020?text=Hallo%2C%20ich%20m%C3%B6chte%20Kontakt%20aufnehmen."
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center text-brand hover:text-highlight transition-colors font-semibold"
                data-analytics="whatsapp_click"
              >
                <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
                  <path
                    d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                  ></path>
                </svg>
                Nachricht senden
              </a>
            </div>
            <div>
              <p class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">E-Mail</p>
              <a
                href="mailto:info@schaden-check24.de"
                class="text-brand hover:text-highlight transition-colors font-semibold"
              >
                info@schaden-check24.de
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Kontaktformular -->
      <div class="bg-white dark:bg-slate-800 rounded-lg shadow-lg p-6 md:p-8">
        <h3 class="text-2xl font-bold text-brand dark:text-white mb-6">Schreiben Sie uns</h3>
        <form id="kontakt-form" class="space-y-5">
          <!-- Name -->
          <div>
            <label for="name" class="block text-sm font-semibold text-gray-900 dark:text-white mb-2">
              Name <span class="text-red-600">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brand focus:border-brand dark:bg-slate-900 dark:border-gray-600 dark:text-white"
              placeholder="Ihr Name"
            />
          </div>

          <!-- E-Mail -->
          <div>
            <label for="email" class="block text-sm font-semibold text-gray-900 dark:text-white mb-2">
              E-Mail <span class="text-red-600">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brand focus:border-brand dark:bg-slate-900 dark:border-gray-600 dark:text-white"
              placeholder="ihre@email.de"
            />
          </div>

          <!-- Telefon (optional) -->
          <div>
            <label for="telefon" class="block text-sm font-semibold text-gray-900 dark:text-white mb-2">
              Telefon (optional)
            </label>
            <input
              type="tel"
              id="telefon"
              name="telefon"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brand focus:border-brand dark:bg-slate-900 dark:border-gray-600 dark:text-white"
              placeholder="+49 123 456789"
            />
          </div>

          <!-- Nachricht -->
          <div>
            <label for="nachricht" class="block text-sm font-semibold text-gray-900 dark:text-white mb-2">
              Ihre Nachricht <span class="text-red-600">*</span>
            </label>
            <textarea
              id="nachricht"
              name="nachricht"
              rows="5"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brand focus:border-brand dark:bg-slate-900 dark:border-gray-600 dark:text-white"
              placeholder="Wie können wir Ihnen helfen?"
            ></textarea>
          </div>

          <!-- DSGVO Checkbox -->
          <div class="flex items-start">
            <div class="flex items-center h-5">
              <input
                type="checkbox"
                id="dsgvo"
                name="dsgvo"
                required
                class="w-4 h-4 text-brand bg-gray-100 border-gray-300 rounded focus:ring-brand focus:ring-2 dark:bg-gray-700 dark:border-gray-600"
              />
            </div>
            <div class="ml-3">
              <label for="dsgvo" class="text-sm text-gray-700 dark:text-gray-300">
                Ich habe die <a href={getPermalink('/datenschutz/')} class="text-brand underline hover:text-highlight"
                  >Datenschutzerklärung</a
                > gelesen. <span class="text-red-600">*</span>
              </label>
            </div>
          </div>

          <!-- Submit Button -->
          <div class="pt-2">
            <button
              type="submit"
              class="w-full btn-primary-brand text-base py-3 px-6 rounded-lg font-semibold transition-all hover:shadow-lg"
            >
              Nachricht senden
            </button>
          </div>

          <!-- Success Message -->
          <div
            id="success-message"
            class="hidden p-4 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg"
          >
            <p class="text-sm text-green-700 dark:text-green-300">
              Vielen Dank für Ihre Nachricht! Wir melden uns schnellstmöglich bei Ihnen.
            </p>
          </div>

          <!-- Error Message -->
          <div
            id="error-message"
            class="hidden p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg"
          >
            <p class="text-sm text-red-700 dark:text-red-300">
              ✗ Fehler beim Senden. Bitte versuchen Sie es erneut oder rufen Sie uns an: +49 2191 7932020
            </p>
          </div>
        </form>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <Testimonials
    title="Das sagen unsere Kunden"
    testimonials={testimonials}
  />

  <!-- FAQs -->
  <section class="py-16 md:py-20 bg-gradient-to-b from-gray-50 to-white dark:from-slate-800 dark:to-slate-900">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-brand dark:text-white mb-4">
          Häufig gestellte Fragen
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-400">
          Wichtige Informationen zur Kontaktaufnahme
        </p>
      </div>

      <div class="space-y-4">
        <details class="group bg-white dark:bg-slate-800 rounded-lg border border-gray-200 dark:border-slate-700 overflow-hidden">
          <summary class="flex justify-between items-center cursor-pointer px-6 py-4 font-semibold text-brand dark:text-white hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors">
            <span>Wie schnell erhalte ich einen Termin?</span>
            <svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="px-6 pb-6 text-gray-600 dark:text-gray-400">
            <p>
              Bei <strong>unverschuldeten Unfällen</strong> oder <strong>dringenden Fällen</strong> sind wir in der Regel bereits <strong>innerhalb von 24 Stunden</strong> bei Ihnen vor Ort. Auch bei geplanten Terminen bemühen wir uns, Ihnen zeitnah einen passenden Termin anzubieten – meist schon am <strong>nächsten oder übernächsten Werktag</strong>. Rufen Sie uns einfach an (+49 2191 7932020), schreiben Sie uns per WhatsApp, oder nutzen Sie unser Kontaktformular. Wir melden uns schnellstmöglich bei Ihnen und vereinbaren einen für Sie passenden Termin.
            </p>
          </div>
        </details>

        <details class="group bg-white dark:bg-slate-800 rounded-lg border border-gray-200 dark:border-slate-700 overflow-hidden">
          <summary class="flex justify-between items-center cursor-pointer px-6 py-4 font-semibold text-brand dark:text-white hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors">
            <span>Kommen Sie auch zu mir nach Hause oder zur Werkstatt?</span>
            <svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="px-6 pb-6 text-gray-600 dark:text-gray-400">
            <p>
              Ja, absolut! Wir kommen direkt zu Ihnen – egal ob <strong>nach Hause</strong>, zur <strong>Arbeit</strong>, zur <strong>Werkstatt</strong> oder zu einem anderen <strong>Wunschort</strong> in Remscheid und Umgebung. Sie müssen Ihr Fahrzeug also nicht zu uns bringen. Der mobile Service ist für Sie besonders bequem und spart Zeit. Wir sind im gesamten <strong>Bergischen Land</strong> unterwegs – von <strong>Remscheid</strong> über <strong>Wuppertal</strong>, <strong>Solingen</strong> und <strong>Leverkusen</strong> bis in ganz <strong>NRW</strong>. Geben Sie uns einfach bei der Terminvereinbarung Ihre Wunschadresse an.
            </p>
          </div>
        </details>

        <details class="group bg-white dark:bg-slate-800 rounded-lg border border-gray-200 dark:border-slate-700 overflow-hidden">
          <summary class="flex justify-between items-center cursor-pointer px-6 py-4 font-semibold text-brand dark:text-white hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors">
            <span>Welche Informationen brauchen Sie von mir?</span>
            <svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="px-6 pb-6 text-gray-600 dark:text-gray-400">
            <p>
              Für eine schnelle Terminvereinbarung benötigen wir folgende Informationen: <strong>Art des Schadens</strong> (Unfall, Parkschaden, Hagelschaden, etc.), <strong>Unfallhergang</strong> (wenn bekannt), <strong>Ihre Kontaktdaten</strong> (Name, Telefon, E-Mail), <strong>Wunschtermin</strong> und <strong>Ort der Begutachtung</strong>. Hilfreich sind auch: <strong>Fahrzeugdaten</strong> (Marke, Modell, Kennzeichen) und ggf. <strong>Unfallgegner-Daten</strong>. Keine Sorge: Wenn Sie nicht alle Informationen parat haben, ist das kein Problem – wir helfen Ihnen gerne weiter und erfassen alles Schritt für Schritt bei der Terminvereinbarung.
            </p>
          </div>
        </details>

        <details class="group bg-white dark:bg-slate-800 rounded-lg border border-gray-200 dark:border-slate-700 overflow-hidden">
          <summary class="flex justify-between items-center cursor-pointer px-6 py-4 font-semibold text-brand dark:text-white hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors">
            <span>Bin ich verpflichtet, den Gutachter der Versicherung zu nehmen?</span>
            <svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="px-6 pb-6 text-gray-600 dark:text-gray-400">
            <p>
              <strong>Nein!</strong> Bei einem <strong>unverschuldeten Unfall</strong> haben Sie als Geschädigter die <strong>freie Wahl des Sachverständigen</strong> – das ist gesetzlich verankert. Die gegnerische Versicherung darf Sie nicht zwingen, deren Gutachter zu akzeptieren. Es ist sogar empfehlenswert, einen <strong>unabhängigen Sachverständigen</strong> zu beauftragen, der ausschließlich <strong>Ihre Interessen</strong> vertritt. Denn der Gutachter der Versicherung arbeitet im Auftrag der Versicherung und versucht oft, die Kosten zu minimieren – zu Ihrem Nachteil. Wir vertreten nur Sie und sorgen dafür, dass alle Ansprüche korrekt ermittelt und durchgesetzt werden.
            </p>
          </div>
        </details>

        <details class="group bg-white dark:bg-slate-800 rounded-lg border border-gray-200 dark:border-slate-700 overflow-hidden">
          <summary class="flex justify-between items-center cursor-pointer px-6 py-4 font-semibold text-brand dark:text-white hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors">
            <span>Was kostet mich die Kontaktaufnahme und Beratung?</span>
            <svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="px-6 pb-6 text-gray-600 dark:text-gray-400">
            <p>
              Die <strong>Kontaktaufnahme und Erstberatung ist für Sie komplett kostenfrei</strong> – egal ob per Telefon, WhatsApp, E-Mail oder über unser Kontaktformular. Wir klären mit Ihnen telefonisch, welches Gutachten Sie benötigen, wie die Abwicklung erfolgt und ob Kosten auf Sie zukommen. Bei <strong>unverschuldeten Unfällen</strong> trägt die <strong>Haftpflichtversicherung des Unfallverursachers</strong> alle Gutachterkosten – das Gutachten ist für Sie also kostenfrei. Bei anderen Schadensfällen beraten wir Sie transparent über die Kosten und Erstattungsmöglichkeiten. Sie gehen durch die Kontaktaufnahme keinerlei Verpflichtungen ein.
            </p>
          </div>
        </details>
      </div>
    </div>
  </section>

  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-6xl">
    <!-- Google Maps Einbettung -->
    <div class="mt-12">
      <h3 class="text-2xl font-bold text-brand dark:text-white mb-6 text-center">So finden Sie uns</h3>

      <!-- Placeholder wenn Cookies nicht akzeptiert -->
      <div id="maps-placeholder" class="rounded-lg overflow-hidden shadow-lg bg-gray-100 dark:bg-slate-800 p-12 text-center">
        <div class="max-w-md mx-auto">
          <svg class="w-16 h-16 mx-auto mb-4 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
          </svg>
          <h4 class="text-xl font-bold text-brand dark:text-white mb-3">Google Maps</h4>
          <p class="text-gray-700 dark:text-gray-300 mb-4">
            Um die interaktive Karte anzuzeigen, müssen Sie Cookies akzeptieren.
          </p>
          <button
            id="enable-maps-btn"
            class="btn-primary-brand text-sm py-2 px-6 rounded-lg font-semibold"
          >
            Cookies akzeptieren & Karte laden
          </button>
          <p class="text-sm text-gray-600 dark:text-gray-400 mt-4">
            <strong>Adresse:</strong><br>
            Kölner Str. 121<br>
            42897 Remscheid
          </p>
        </div>
      </div>

      <!-- Google Maps iframe (initially hidden) -->
      <div id="maps-container" class="rounded-lg overflow-hidden shadow-lg hidden">
        <iframe
          id="maps-iframe"
          data-src="https://www.google.com/maps?q=KFZ+Gutachter+Remscheid+%26+KFZ+Sachverst%C3%A4ndiger+%7C+Unfallgutachten+bei+SchadenCheck&hl=de&output=embed&t=k&z=20"
          width="100%"
          height="450"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="KFZ Gutachter Remscheid & KFZ Sachverständiger Unfallgutachten bei SchadenCheck Standort - Kölner Str. 121, 42897 Remscheid"
        ></iframe>
      </div>
    </div>
  </section>

  <script is:inline src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
  <script is:inline>
    (function() { emailjs.init('F8-ObLhdR40QituD6'); })();
  </script>

  <script>
    declare const emailjs: any;

    function initKontaktPage() {
      // Form handling
      const form = document.getElementById('kontakt-form') as HTMLFormElement;
      if (!form) return;

      const successMessage = document.getElementById('success-message');
      const errorMessage = document.getElementById('error-message');
      const submitButton = form.querySelector('button[type="submit"]') as HTMLButtonElement;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        successMessage?.classList.add('hidden');
        errorMessage?.classList.add('hidden');

        if (submitButton) {
          submitButton.disabled = true;
          submitButton.textContent = 'Wird gesendet...';
        }

        try {
          const formDataObj = new FormData(form);

          // Felder mappen: Seite (deutsch) → EmailJS Template-Variablen (englisch)
          const templateParams = {
            name: formDataObj.get('name'),
            email: formDataObj.get('email'),
            phone: formDataObj.get('telefon') || '',
            message: formDataObj.get('nachricht'),
          };

          await emailjs.send('service_zxis7xd', 'template_ylbrteq', templateParams);

          successMessage?.classList.remove('hidden');
          form.reset();
          successMessage?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        } catch (error) {
          console.error('Form submission error:', error);
          errorMessage?.classList.remove('hidden');
          errorMessage?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        } finally {
          if (submitButton) {
            submitButton.disabled = false;
            submitButton.textContent = 'Nachricht senden';
          }
        }
      });

      // Google Maps Cookie Logic
      const COOKIE_NAME = 'schadencheck_cookie_consent';
      const mapsPlaceholder = document.getElementById('maps-placeholder');
      const mapsContainer = document.getElementById('maps-container');
      const mapsIframe = document.getElementById('maps-iframe') as HTMLIFrameElement;
      const enableMapsBtn = document.getElementById('enable-maps-btn');

      function getCookie(name: string): string | null {
        const nameEQ = name + '=';
        const ca = document.cookie.split(';');
        for (let i = 0; i < ca.length; i++) {
          let c = ca[i];
          while (c.charAt(0) === ' ') c = c.substring(1, c.length);
          if (c.indexOf(nameEQ) === 0) return c.substring(nameEQ.length, c.length);
        }
        return null;
      }

      function setCookie(name: string, value: string, days: number) {
        const expires = new Date();
        expires.setTime(expires.getTime() + days * 24 * 60 * 60 * 1000);
        document.cookie = `${name}=${value};expires=${expires.toUTCString()};path=/;SameSite=Lax`;
      }

      function loadGoogleMaps() {
        if (mapsIframe && mapsContainer && mapsPlaceholder) {
          const src = mapsIframe.getAttribute('data-src');
          if (src) {
            mapsIframe.setAttribute('src', src);
          }
          mapsPlaceholder.classList.add('hidden');
          mapsContainer.classList.remove('hidden');
        }
      }

      // Check if user has already accepted cookies
      const consent = getCookie(COOKIE_NAME);
      if (consent === 'all') {
        loadGoogleMaps();
      }

      // Listen for cookie acceptance event from banner
      window.addEventListener('cookies-accepted', (event: Event) => {
        const customEvent = event as CustomEvent;
        if (customEvent.detail?.maps) {
          loadGoogleMaps();
        }
      });

      // Enable maps button click
      enableMapsBtn?.addEventListener('click', () => {
        setCookie(COOKIE_NAME, 'all', 365);
        loadGoogleMaps();
        window.dispatchEvent(new CustomEvent('cookies-accepted', { detail: { maps: true } }));
      });
    }

    // Run on initial load and after each View Transition navigation
    initKontaktPage();
    document.addEventListener('astro:page-load', initKontaktPage);
  </script>
</Layout>
