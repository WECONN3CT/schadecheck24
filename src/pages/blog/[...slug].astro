---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getPermalink, getAsset } from '~/utils/permalinks';

export async function getStaticPaths() {
  const posts = await getCollection('post');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'post'>;
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date | undefined) {
  if (!date) return '';
  return new Date(date).toLocaleDateString('de-DE', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

const metadata = {
  title: post.data.title,
  description: post.data.excerpt || '',
  canonical: `https://schaden-check24.de/blog/${post.id}/`,
  openGraph: {
    type: 'article',
    url: `https://schaden-check24.de/blog/${post.id}/`,
    title: post.data.title,
    description: post.data.excerpt || '',
    siteName: 'KFZ Gutachter Remscheid & KFZ Sachverständiger Unfallgutachten bei SchadenCheck',
    locale: 'de_DE',
  },
};
---

<Layout metadata={metadata}>
  <!-- Article Header -->
  <article class="max-w-4xl mx-auto px-4 sm:px-6 py-12 md:py-16">
    <header class="mb-8">
      <div class="mb-4">
        <a
          href={getPermalink('/blog/')}
          class="inline-flex items-center text-primary-600 dark:text-primary-400 hover:underline font-semibold"
        >
          ← Zurück zum Blog
        </a>
      </div>

      {
        post.data.category && (
          <span class="inline-block px-3 py-1 text-sm font-semibold text-primary-600 dark:text-primary-400 bg-primary-50 dark:bg-primary-900/30 rounded-full mb-4">
            {post.data.category}
          </span>
        )
      }

      <h1 id="blog-post-heading" class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4">
        {post.data.title}
      </h1>

      <div class="flex items-center gap-4 text-gray-600 dark:text-gray-400">
        {
          post.data.author && (
            <span class="font-medium">
              Von <span class="text-gray-900 dark:text-white">{post.data.author}</span>
            </span>
          )
        }
        <span>•</span>
        <time datetime={post.data.publishDate?.toISOString()}>
          {formatDate(post.data.publishDate)}
        </time>
        {
          post.data.updateDate && (
            <>
              <span>•</span>
              <span class="text-sm">Aktualisiert: {formatDate(post.data.updateDate)}</span>
            </>
          )
        }
      </div>
    </header>

    {
      post.data.image && (
        <div class="mb-12 rounded-lg overflow-hidden">
          <img
            src={getAsset(post.data.image)}
            alt={post.data.title}
            class="w-full h-auto object-cover"
            loading="eager"
            width="1200"
            height="675"
          />
        </div>
      )
    }

    <div
      class="prose prose-lg dark:prose-invert max-w-none prose-headings:font-bold prose-headings:text-gray-900 dark:prose-headings:text-white prose-a:text-primary-600 dark:prose-a:text-primary-400 prose-a:no-underline hover:prose-a:underline prose-img:rounded-lg"
    >
      <Content />
    </div>

    {
      post.data.tags && post.data.tags.length > 0 && (
        <div class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-700">
          <h3 class="text-lg font-semibold mb-4 text-gray-900 dark:text-white">Tags:</h3>
          <div class="flex flex-wrap gap-2">
            {post.data.tags.map((tag) => (
              <span class="px-3 py-1 text-sm bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 rounded-full">
                #{tag}
              </span>
            ))}
          </div>
        </div>
      )
    }
  </article>

  <!-- Call to Action -->
  <CallToAction
    title="Unfallschaden? Wir sind für Sie da!"
    subtitle="Kostenlose Erstberatung und schnelle Schadensabwicklung – professionell und unabhängig."
    actions={[
      {
        variant: 'primary',
        text: 'Jetzt Schaden melden',
        href: getPermalink('/schaden-melden/'),
      },
      {
        variant: 'secondary',
        text: 'Mehr zu unseren Leistungen',
        href: getPermalink('/leistungen/'),
      },
    ]}
  />
</Layout>

<style>
  @media (min-width: 1024px) {
    /* Desktop offset so the fixed header doesn't cover the blog post title */
    #blog-post-heading {
      margin-top: 120px;
    }
  }
</style>
